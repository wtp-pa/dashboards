# Local environment variables for pipeline scripts.
# Copy to .env (which is gitignored) and fill in.

# OpenStates API key — get one at https://openstates.org/accounts/profile/
# Free tier: 500 req/day. Used by pipeline/elected-officials/fetch_*.py.
# In CI, set as a repo secret and reference from the workflow.
OPENSTATES_API_KEY=
