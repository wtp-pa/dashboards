# Local environment variables for pipeline scripts.
# Copy to .env (which is gitignored) and fill in.

# OpenStates API key — get one at https://openstates.org/accounts/profile/
# Free tier: 500 req/day. Used by pipeline/elected-officials/fetch_*.py.
# In CI, set as a repo secret and reference from the workflow.
OPENSTATES_API_KEY=

# Same key (or a different one to sandbox client-side calls). Astro
# embeds anything prefixed PUBLIC_ into the static HTML/JS, so this
# value WILL be visible in the deployed site source. The "Use my
# location" lookup on /elected-officials hits OpenStates /people.geo
# from the browser using this key.
PUBLIC_OPENSTATES_API_KEY=
