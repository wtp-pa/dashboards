---
/**
 * Cross-dashboard switcher. Renders just the <nav> element — the consumer
 * decides whether to place it inline in the header (md+) or as a strip
 * below the header (mobile). Source of truth: config.portfolio.projects.
 *
 * Status semantics:
 *   live          → plain link
 *   pre-release   → link + small italic "beta" trailing
 *   coming-soon   → filtered out (lives only on the portfolio card grid)
 */

import { config } from '../../config';

export interface Props {
  activeSlug?: string;
}

const { activeSlug } = Astro.props;
const dashboards = config.portfolio.projects.filter((d) => d.status !== 'coming-soon');

const labels: Record<string, string> = {
  budget: 'Budget',
  legislation: 'Legislation',
  'elected-officials': 'Officials',
  local: 'Local',
};
---

<nav class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
  {dashboards.map((d) => {
    const label = labels[d.slug] ?? d.name;
    const isActive = d.slug === activeSlug;
    const isBeta = d.status === 'pre-release';

    const linkClass = isActive
      ? 'text-white font-semibold no-underline'
      : 'text-wtp-cream/70 no-underline hover:text-wtp-sky transition';

    return (
      <a href={`/${d.slug}/`} class={linkClass} aria-current={isActive ? 'page' : undefined}>
        {label}
        {isBeta && (
          <span class="ml-0.5 italic text-[11px] text-wtp-gold/70">beta</span>
        )}
      </a>
    );
  })}
</nav>
