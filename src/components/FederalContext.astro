---
import federalData from '../../data/federal-funds.json';
import BudgetBreakdown from './BudgetBreakdown.astro';

const totalB = (federalData.totalFederalFundsToPaUSD / 1e9).toFixed(0);
const medicaidProgram = federalData.majorPrograms.find(p => p.key === 'medicaid');
const medicaidB = medicaidProgram ? (medicaidProgram.amountUSD / 1e9).toFixed(0) : '17';
---

<section>
  <p class="text-xs uppercase tracking-[0.2em] text-wtp-sky">Federal dependency</p>
  <h2 class="mt-2 text-3xl font-bold md:text-4xl">The other ${totalB} billion</h2>

  <p class="mt-6 max-w-3xl text-base leading-relaxed text-white/80">
    Pennsylvania doesn't only spend the <strong class="text-white">$50 billion</strong> from its General Fund. It also receives roughly <strong class="text-white">${totalB} billion</strong> in federal dollars each year — a parallel river of money that flows into Medicaid, education, food assistance, transportation, and dozens of smaller programs. About a third of that, <strong class="text-white">~${medicaidB} billion</strong>, is the federal share of PA's Medicaid program.
  </p>

  <p class="mt-4 max-w-3xl text-base leading-relaxed text-white/80">
    The structural deficit ticking at the top of this page <strong class="text-wtp-sky">assumes that money keeps flowing</strong>. If it gets cut, the gap grows fast.
  </p>

  <div class="mt-10">
    <BudgetBreakdown
      title="Federal dollars flowing into PA"
      totalUSD={federalData.totalFederalFundsToPaUSD}
      fiscalYear={federalData.fiscalYear}
      segments={federalData.majorPrograms}
      source={federalData.source.primary}
    />
  </div>

  <div class="mt-10 rounded-lg border border-wtp-red/30 bg-wtp-red/5 p-6 md:p-8">
    <div class="flex items-start gap-3">
      <span class="mt-0.5 text-2xl leading-none">⚠</span>
      <div>
        <h3 class="text-xl font-bold text-wtp-red">Cliff scenarios</h3>
        <p class="mt-2 text-sm text-white/70">
          What happens to PA's structural deficit if any of these federal cuts materialize:
        </p>
      </div>
    </div>

    <dl class="mt-6 space-y-5">
      {federalData.riskScenarios.map((scenario) => (
        <div class="flex items-start gap-4 border-l-2 border-wtp-red/40 pl-4">
          <div class="flex-1">
            <dt class="font-semibold text-white">{scenario.label}</dt>
            <dd class="mt-1 text-sm leading-relaxed text-white/70">{scenario.shortDescription}</dd>
          </div>
          <div class="flex-shrink-0 text-right">
            <div class="font-mono text-2xl font-bold text-wtp-red md:text-3xl">
              +${(scenario.deficitImpactUSD / 1e9).toFixed(1)}B
            </div>
            <div class="text-xs text-white/40">added to deficit</div>
          </div>
        </div>
      ))}
    </dl>

    <p class="mt-6 text-xs text-white/40">
      Sources: KFF Medicaid State Indicators, CMS FMAP tables, PA Office of the Budget federal funds reporting. Scenario impacts are estimates based on current program sizes; actual cuts would depend on specific federal legislation.
    </p>
  </div>
</section>
