---
interface Segment {
  key: string;
  label: string;
  amountUSD: number;
  shortDescription?: string;
}

interface Props {
  title: string;
  totalUSD: number;
  fiscalYear: string;
  segments: Segment[];
  source: string;
}

const { title, totalUSD, fiscalYear, segments, source } = Astro.props;

const SEGMENT_COLORS = [
  "bg-wtp-red",
  "bg-wtp-sky",
  "bg-wtp-indigo",
  "bg-white/30",
  "bg-white/15",
  "bg-white/10",
];

const items = segments.map((seg, i) => ({
  ...seg,
  pct: (seg.amountUSD / totalUSD) * 100,
  colorClass: SEGMENT_COLORS[i % SEGMENT_COLORS.length],
}));

const totalB = (totalUSD / 1e9).toFixed(1);
---

<section class="rounded-lg border border-white/10 bg-surface p-6 md:p-8">
  <header class="flex flex-col gap-1 md:flex-row md:items-baseline md:justify-between md:gap-4">
    <h3 class="text-xl font-bold md:text-2xl">{title}</h3>
    <div class="text-sm text-white/60">
      Total <span class="font-mono text-white">${totalB}B</span> · FY {fiscalYear}
    </div>
  </header>

  <div
    class="mt-6 flex h-10 w-full overflow-hidden rounded-md md:h-12"
    role="img"
    aria-label={`${title} breakdown bar`}
  >
    {items.map((it) => (
      <div
        class={it.colorClass}
        style={`width: ${it.pct}%`}
        title={`${it.label}: $${(it.amountUSD / 1e9).toFixed(1)}B (${it.pct.toFixed(0)}%)`}
      ></div>
    ))}
  </div>

  <dl class="mt-6 space-y-4">
    {items.map((it) => (
      <div class="flex items-start gap-3">
        <div class={`mt-1.5 h-3 w-3 flex-shrink-0 rounded-sm ${it.colorClass}`}></div>
        <div class="flex-1">
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <dt class="font-semibold">{it.label}</dt>
            <dd class="text-sm tabular-nums text-white/70">
              ${(it.amountUSD / 1e9).toFixed(1)}B
              <span class="ml-2 text-white/40">{it.pct.toFixed(0)}%</span>
            </dd>
          </div>
          {it.shortDescription && (
            <p class="mt-1 text-xs leading-relaxed text-white/50">
              {it.shortDescription}
            </p>
          )}
        </div>
      </div>
    ))}
  </dl>

  <p class="mt-6 text-xs text-white/40">Source: {source}</p>
</section>
