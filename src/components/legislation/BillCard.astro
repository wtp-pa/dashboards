---
import platform from '../../../data/legislation/platform.json';

type Alignment = 'aligned' | 'mixed' | 'opposed' | 'topic-only' | 'under-review';
type Source = 'manual' | 'auto' | 'none';

interface Match {
  positionId: string;
  score: number;
  evidence: string;
  mechanism: 'keyword' | 'tfidf';
  autoAlignment?: 'likely-aligned' | 'likely-opposed' | 'topic-only';
  autoConfidence?: number;
  alignedVerbs?: string[];
  opposedVerbs?: string[];
}

export interface Props {
  id: string;
  chamber: string;
  title: string;
  sponsor: string;
  status: string;
  lastAction: string;
  url: string;
  summary: string;
  matches: Match[];
  alignment: Alignment;
  alignmentSource: Source;
  alignmentConfidence?: number;
  reviewNote?: string;
  reviewedBy?: string;
  reviewedAt?: string;
}

const {
  id, chamber, title, sponsor, status, lastAction, url, summary,
  matches, alignment, alignmentSource, alignmentConfidence,
  reviewNote, reviewedBy, reviewedAt,
} = Astro.props;

const alignmentMeta: Record<Alignment, { label: string; autoLabel: string; cls: string; dot: string }> = {
  aligned: {
    label: 'Aligned with platform',
    autoLabel: 'Likely aligned',
    cls: 'border-wtp-sky/40 bg-wtp-sky/10 text-wtp-sky',
    dot: 'bg-wtp-sky',
  },
  mixed: {
    label: 'Mixed alignment',
    autoLabel: 'Mixed alignment',
    cls: 'border-wtp-gold/40 bg-wtp-gold/10 text-wtp-gold',
    dot: 'bg-wtp-gold',
  },
  opposed: {
    label: 'Opposed to platform',
    autoLabel: 'Likely opposed',
    cls: 'border-wtp-red/40 bg-wtp-red/10 text-wtp-red',
    dot: 'bg-wtp-red',
  },
  'topic-only': {
    label: 'Touches our platform',
    autoLabel: 'Touches our platform',
    cls: 'border-white/15 bg-white/5 text-wtp-cream/70',
    dot: 'bg-wtp-cream/50',
  },
  'under-review': {
    label: 'Under review',
    autoLabel: 'Under review',
    cls: 'border-white/15 bg-white/5 text-wtp-cream/60',
    dot: 'bg-wtp-cream/40',
  },
};

const meta = alignmentMeta[alignment];
const badgeLabel = alignmentSource === 'auto' ? meta.autoLabel : meta.label;

// Look up the full position object for each match, attaching pillar info and
// the evidence string from the matcher.
const matchDetails = matches.map((m) => {
  for (const pillar of platform.pillars) {
    const position = pillar.positions.find((p) => p.id === m.positionId);
    if (position) {
      return {
        ...position,
        pillarName: pillar.name,
        pillarId: pillar.id,
        score: m.score,
        evidence: m.evidence,
        mechanism: m.mechanism,
        autoAlignment: m.autoAlignment,
        autoConfidence: m.autoConfidence,
        alignedVerbs: m.alignedVerbs ?? [],
        opposedVerbs: m.opposedVerbs ?? [],
      };
    }
  }
  return null;
}).filter(<T,>(x: T | null): x is T => x !== null);

const formatDate = (iso: string) =>
  new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
    .format(new Date(iso + 'T00:00:00'));
---

<details class="group rounded-lg border border-white/10 bg-surface/40 transition hover:border-white/20">
  <summary class="flex cursor-pointer list-none flex-col gap-3 p-5 md:flex-row md:items-start md:gap-5">
    <div class="flex flex-shrink-0 flex-col items-start gap-1 self-start">
      <div class={`flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium ${meta.cls}`}>
        <span class={`inline-block h-1.5 w-1.5 rounded-full ${meta.dot}`}></span>
        <span>{badgeLabel}</span>
      </div>
      <div class="pl-1 text-[10px] uppercase tracking-wider text-wtp-cream/40">
        {alignmentSource === 'manual' && 'Editor reviewed'}
        {alignmentSource === 'auto' && alignmentConfidence !== undefined && `Auto · ${Math.round(alignmentConfidence * 100)}% confidence`}
        {alignmentSource === 'none' && 'No clear signal'}
      </div>
    </div>
    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 text-xs text-wtp-cream/50">
        <span class="font-mono font-semibold text-wtp-cream/70">{id}</span>
        <span>·</span>
        <span>{chamber}</span>
        <span>·</span>
        <span>{sponsor}</span>
      </div>
      <h3 class="mt-1 text-base font-semibold leading-snug text-white md:text-lg">{title}</h3>
      <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-wtp-cream/50">
        <span>{status}</span>
        <span>·</span>
        <span>Last action {formatDate(lastAction)}</span>
      </div>
    </div>
    <div class="flex-shrink-0 self-start text-xs text-wtp-cream/40 transition group-open:rotate-180" aria-hidden="true">▼</div>
  </summary>

  <div class="border-t border-white/5 px-5 pb-5 pt-4 text-sm leading-relaxed">
    <p class="text-wtp-cream/80">{summary}</p>

    {matchDetails.length > 0 && (
      <div class="mt-5">
        <div class="text-xs uppercase tracking-[0.18em] text-wtp-cream/40">Why we flagged this</div>
        <ul class="mt-2 space-y-2">
          {matchDetails.map((p) => (
            <li class="rounded-md border border-white/10 bg-white/5 p-3">
              <div class="flex items-baseline justify-between gap-3">
                <div class="text-xs uppercase tracking-wider text-wtp-sky">{p.pillarName}</div>
                <div class="text-xs text-wtp-cream/40" title={`${p.mechanism === 'keyword' ? 'Direct keyword match' : 'TF-IDF cosine similarity'} score`}>
                  {p.mechanism === 'keyword' ? '✦' : '~'} {p.score.toFixed(2)}
                </div>
              </div>
              <div class="mt-1 text-sm font-medium text-white">{p.title}</div>
              <div class="mt-1 text-xs italic text-wtp-cream/50">{p.evidence}</div>
              {(p.alignedVerbs.length > 0 || p.opposedVerbs.length > 0) && (
                <div class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-xs">
                  {p.alignedVerbs.length > 0 && (
                    <span class="text-wtp-sky/80">
                      Aligned-direction verbs: <span class="font-mono text-wtp-sky">{p.alignedVerbs.join(', ')}</span>
                    </span>
                  )}
                  {p.opposedVerbs.length > 0 && (
                    <span class="text-wtp-red/80">
                      Opposed-direction verbs: <span class="font-mono text-wtp-red">{p.opposedVerbs.join(', ')}</span>
                    </span>
                  )}
                </div>
              )}
              <div class="mt-2 text-xs text-wtp-cream/60">{p.summary}</div>
            </li>
          ))}
        </ul>
      </div>
    )}

    {reviewNote && (
      <div class="mt-5">
        <div class="text-xs uppercase tracking-[0.18em] text-wtp-cream/40">Editor's note</div>
        <p class="mt-2 text-sm text-wtp-cream/80">{reviewNote}</p>
        {(reviewedBy || reviewedAt) && (
          <p class="mt-1 text-xs text-wtp-cream/40">
            {reviewedBy}{reviewedBy && reviewedAt ? ' · ' : ''}{reviewedAt && formatDate(reviewedAt)}
          </p>
        )}
      </div>
    )}

    {alignment === 'under-review' && matchDetails.length === 0 && (
      <p class="mt-5 text-xs italic text-wtp-cream/40">
        No platform planks were auto-detected and no editorial review has been recorded yet.
      </p>
    )}

    <div class="mt-5">
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-sm text-wtp-sky no-underline hover:underline"
      >
        Read the bill on palegis.us →
      </a>
    </div>
  </div>
</details>

<style>
  details > summary::-webkit-details-marker { display: none; }
</style>
