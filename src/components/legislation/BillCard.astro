---
import platform from '../../../data/legislation/platform.json';

type Alignment = 'aligned' | 'mixed' | 'opposed' | 'under-review';

export interface Props {
  id: string;
  chamber: string;
  title: string;
  sponsor: string;
  status: string;
  lastAction: string;
  url: string;
  summary: string;
  matchedPositions: string[];
  alignment: Alignment;
  reviewNote?: string;
  reviewedBy?: string;
  reviewedAt?: string;
}

const {
  id, chamber, title, sponsor, status, lastAction, url, summary,
  matchedPositions, alignment, reviewNote, reviewedBy, reviewedAt,
} = Astro.props;

const alignmentMeta: Record<Alignment, { label: string; cls: string; dot: string }> = {
  aligned: {
    label: 'Aligned with platform',
    cls: 'border-wtp-sky/40 bg-wtp-sky/10 text-wtp-sky',
    dot: 'bg-wtp-sky',
  },
  mixed: {
    label: 'Mixed alignment',
    cls: 'border-wtp-gold/40 bg-wtp-gold/10 text-wtp-gold',
    dot: 'bg-wtp-gold',
  },
  opposed: {
    label: 'Opposed to platform',
    cls: 'border-wtp-red/40 bg-wtp-red/10 text-wtp-red',
    dot: 'bg-wtp-red',
  },
  'under-review': {
    label: 'Under review',
    cls: 'border-white/15 bg-white/5 text-wtp-cream/60',
    dot: 'bg-wtp-cream/40',
  },
};

const meta = alignmentMeta[alignment];

// Look up the full position object for each matched position ID, with the
// pillar it belongs to.
const positionDetails = matchedPositions.map((posId) => {
  for (const pillar of platform.pillars) {
    const position = pillar.positions.find((p) => p.id === posId);
    if (position) return { ...position, pillarName: pillar.name, pillarId: pillar.id };
  }
  return null;
}).filter(<T>(x: T | null): x is T => x !== null);

const formatDate = (iso: string) =>
  new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
    .format(new Date(iso + 'T00:00:00'));
---

<details class="group rounded-lg border border-white/10 bg-surface/40 transition hover:border-white/20">
  <summary class="flex cursor-pointer list-none flex-col gap-3 p-5 md:flex-row md:items-start md:gap-5">
    <div class={`flex flex-shrink-0 items-center gap-2 self-start rounded-full border px-3 py-1 text-xs font-medium ${meta.cls}`}>
      <span class={`inline-block h-1.5 w-1.5 rounded-full ${meta.dot}`}></span>
      <span>{meta.label}</span>
    </div>
    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 text-xs text-wtp-cream/50">
        <span class="font-mono font-semibold text-wtp-cream/70">{id}</span>
        <span>·</span>
        <span>{chamber}</span>
        <span>·</span>
        <span>{sponsor}</span>
      </div>
      <h3 class="mt-1 text-base font-semibold leading-snug text-white md:text-lg">{title}</h3>
      <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-wtp-cream/50">
        <span>{status}</span>
        <span>·</span>
        <span>Last action {formatDate(lastAction)}</span>
      </div>
    </div>
    <div class="flex-shrink-0 self-start text-xs text-wtp-cream/40 transition group-open:rotate-180" aria-hidden="true">▼</div>
  </summary>

  <div class="border-t border-white/5 px-5 pb-5 pt-4 text-sm leading-relaxed">
    <p class="text-wtp-cream/80">{summary}</p>

    {positionDetails.length > 0 && (
      <div class="mt-5">
        <div class="text-xs uppercase tracking-[0.18em] text-wtp-cream/40">Touches platform planks</div>
        <ul class="mt-2 space-y-2">
          {positionDetails.map((p) => (
            <li class="rounded-md border border-white/10 bg-white/5 p-3">
              <div class="text-xs uppercase tracking-wider text-wtp-sky">{p.pillarName}</div>
              <div class="mt-1 text-sm font-medium text-white">{p.title}</div>
              <div class="mt-1 text-xs text-wtp-cream/60">{p.summary}</div>
            </li>
          ))}
        </ul>
      </div>
    )}

    {reviewNote && (
      <div class="mt-5">
        <div class="text-xs uppercase tracking-[0.18em] text-wtp-cream/40">Editor's note</div>
        <p class="mt-2 text-sm text-wtp-cream/80">{reviewNote}</p>
        {(reviewedBy || reviewedAt) && (
          <p class="mt-1 text-xs text-wtp-cream/40">
            {reviewedBy}{reviewedBy && reviewedAt ? ' · ' : ''}{reviewedAt && formatDate(reviewedAt)}
          </p>
        )}
      </div>
    )}

    {alignment === 'under-review' && positionDetails.length === 0 && (
      <p class="mt-5 text-xs italic text-wtp-cream/40">
        No platform planks were auto-detected and no editorial review has been recorded yet.
      </p>
    )}

    <div class="mt-5">
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-sm text-wtp-sky no-underline hover:underline"
      >
        Read the bill on palegis.us →
      </a>
    </div>
  </div>
</details>

<style>
  details > summary::-webkit-details-marker { display: none; }
</style>
