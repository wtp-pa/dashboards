---
import platform from '../../../data/legislation/platform.json';

interface PillarBreakdown {
  pillarId: string;
  pillarName: string;
  withPlatform: number;
  againstPlatform: number;
  noted?: number;
}

export interface Props {
  id: string;
  name: string;
  title: string;
  district: string;
  party: 'D' | 'R' | 'I' | string;
  region?: string;
  counties?: string[];
  alignmentRate: number | null;
  scorableVotes: number;
  totalVotes: number;
  byPillar?: PillarBreakdown[];
  currentTermStart?: number | null;
  currentTermEnd?: number | null;
  chamber?: string;
}

const {
  id, name, title, district, party, region, counties,
  alignmentRate, scorableVotes, totalVotes,
  byPillar = [],
  currentTermStart, currentTermEnd, chamber,
} = Astro.props;

const partyMeta: Record<string, { label: string; cls: string }> = {
  D: { label: 'Democrat', cls: 'border-wtp-sky/40 bg-wtp-sky/10 text-wtp-sky' },
  R: { label: 'Republican', cls: 'border-wtp-red/40 bg-wtp-red/10 text-wtp-red' },
  I: { label: 'Independent', cls: 'border-wtp-gold/40 bg-wtp-gold/10 text-wtp-gold' },
};
const partyTag = partyMeta[party] ?? { label: party, cls: 'border-white/20 bg-white/5 text-wtp-cream/70' };

const ratePercent = alignmentRate === null ? null : Math.round(alignmentRate * 100);
const rateColor =
  ratePercent === null
    ? 'text-wtp-cream/40'
    : ratePercent >= 67
      ? 'text-wtp-sky'
      : ratePercent >= 34
        ? 'text-wtp-gold'
        : 'text-wtp-red';

const subtitle = counties && counties.length > 0
  ? `${district} · ${counties.slice(0, 2).join(', ')}${counties.length > 2 ? ' +' : ''}`
  : district;

// PA Senate=4yr, House=2yr — drives the term-length label.
const termYears = chamber === 'House' ? 2 : 4;
const hasTerm = typeof currentTermStart === 'number' && typeof currentTermEnd === 'number';

// Build the mini-bar data: only pillars where this official has cast at
// least one scorable vote. Sorted by total votes (most-engaged first), top 3.
type Bar = { pillarId: string; pillarName: string; withCount: number; againstCount: number; notedCount: number; total: number };
const pillarOrder = platform.pillars.map((p) => p.id);
const pillarShortNames: Record<string, string> = {
  community: 'Community',
  'health-environment': 'Health & env',
  constitutional: 'Constitutional',
  'honest-government': 'Honest gov',
  economic: 'Economic',
};

const allBars: Bar[] = byPillar
  .map((b) => ({
    pillarId: b.pillarId,
    pillarName: pillarShortNames[b.pillarId] ?? b.pillarName,
    withCount: b.withPlatform,
    againstCount: b.againstPlatform,
    notedCount: b.noted ?? 0,
    total: b.withPlatform + b.againstPlatform + (b.noted ?? 0),
  }))
  .filter((b) => b.total > 0)
  .sort((a, b) => {
    if (b.total !== a.total) return b.total - a.total;
    return pillarOrder.indexOf(a.pillarId) - pillarOrder.indexOf(b.pillarId);
  });

const visibleBars = allBars.slice(0, 3);
const maxBarTotal = Math.max(1, ...allBars.map((b) => b.total));
const hiddenPillarCount = allBars.length - visibleBars.length;
---

<a
  href={`/elected-officials/${id}/`}
  class="group flex flex-col gap-3 rounded-lg border border-white/10 bg-surface/40 p-5 no-underline transition hover:border-wtp-sky/40 hover:bg-surface/60"
>
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <div class="flex flex-wrap items-center gap-2 text-xs text-wtp-cream/50">
        <span>{title}</span>
        <span>·</span>
        <span>{subtitle}</span>
      </div>
      <h3 class="mt-1 truncate text-lg font-semibold text-white group-hover:text-wtp-sky">{name}</h3>
      {region && <div class="mt-0.5 text-xs text-wtp-cream/40">{region}</div>}
      {hasTerm && (
        <div class="mt-1 text-[11px] text-wtp-cream/50">
          Term {currentTermStart}–{currentTermEnd}
          <span class="text-wtp-cream/30"> · {termYears}-year seat</span>
        </div>
      )}
    </div>
    <span class={`flex-shrink-0 rounded-full border px-2.5 py-0.5 text-xs font-medium ${partyTag.cls}`}>
      {party}
    </span>
  </div>

  <div class="mt-1 border-t border-white/5 pt-3">
    <div class="flex items-baseline justify-between gap-3">
      <div class="min-w-0">
        <div class="text-xs uppercase tracking-wider text-wtp-cream/40">Aligns with platform</div>
        <div class="mt-1 flex items-baseline gap-2">
          <span class={`text-2xl font-bold ${rateColor}`}>
            {ratePercent === null ? '—' : `${ratePercent}%`}
          </span>
          <span class="text-xs text-wtp-cream/50">
            {scorableVotes} of {totalVotes} scorable
          </span>
        </div>
      </div>
      <span class="text-sm text-wtp-sky opacity-0 transition group-hover:opacity-100">View →</span>
    </div>

    {visibleBars.length > 0 ? (
      <div class="mt-4">
        <div class="text-[11px] uppercase tracking-wider text-wtp-cream/40">Most active on</div>
        <div class="mt-2 space-y-1.5">
          {visibleBars.map((bar) => {
            const widthPct = Math.round((bar.total / maxBarTotal) * 100);
            const withPct = bar.total ? (bar.withCount / bar.total) * 100 : 0;
            const againstPct = bar.total ? (bar.againstCount / bar.total) * 100 : 0;
            const notedPct = bar.total ? (bar.notedCount / bar.total) * 100 : 0;
            const summary = [
              bar.withCount > 0 ? `${bar.withCount} with` : null,
              bar.againstCount > 0 ? `${bar.againstCount} against` : null,
              bar.notedCount > 0 ? `${bar.notedCount} unscored` : null,
            ].filter(Boolean).join(' · ');
            return (
              <div class="flex items-center gap-2 text-xs" title={summary}>
                <span class="w-24 flex-shrink-0 truncate text-wtp-cream/70">{bar.pillarName}</span>
                <span class="relative h-2 flex-1 overflow-hidden rounded-full bg-white/5">
                  <span class="absolute inset-y-0 left-0 flex h-full" style={`width: ${widthPct}%`}>
                    <span class="bg-wtp-sky" style={`width: ${withPct}%`}></span>
                    <span class="bg-wtp-red" style={`width: ${againstPct}%`}></span>
                    <span class="bg-wtp-cream/30" style={`width: ${notedPct}%`}></span>
                  </span>
                </span>
                <span class="w-10 flex-shrink-0 text-right font-mono text-[11px] text-wtp-cream/60">
                  {bar.total}
                </span>
              </div>
            );
          })}
        </div>
        {hiddenPillarCount > 0 && (
          <div class="mt-2 text-[11px] text-wtp-cream/40">
            +{hiddenPillarCount} more pillar{hiddenPillarCount === 1 ? '' : 's'}
          </div>
        )}
        <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-[10px] text-wtp-cream/40">
          <span class="flex items-center gap-1"><span class="h-1.5 w-1.5 rounded-full bg-wtp-sky"></span>with platform</span>
          <span class="flex items-center gap-1"><span class="h-1.5 w-1.5 rounded-full bg-wtp-red"></span>against</span>
          <span class="flex items-center gap-1"><span class="h-1.5 w-1.5 rounded-full bg-wtp-cream/30"></span>unscored</span>
        </div>
      </div>
    ) : (
      <div class="mt-3 text-[11px] italic text-wtp-cream/40">
        No votes on platform-touching bills yet.
      </div>
    )}
  </div>
</a>
