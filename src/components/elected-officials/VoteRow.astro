---
export interface Props {
  billId: string;
  billTitle: string;
  billUrl?: string;
  vote: 'yea' | 'nay' | 'abstain' | 'absent' | string;
  date: string;
  billAlignment: 'aligned' | 'mixed' | 'opposed' | 'under-review';
  directionRelativeToPlatform?: 'with' | 'against' | null;
}

const { billId, billTitle, billUrl, vote, date, billAlignment, directionRelativeToPlatform } = Astro.props;

const voteMeta: Record<string, { label: string; cls: string }> = {
  yea:     { label: 'YEA',     cls: 'border-wtp-sky/40 bg-wtp-sky/10 text-wtp-sky' },
  nay:     { label: 'NAY',     cls: 'border-wtp-red/40 bg-wtp-red/10 text-wtp-red' },
  abstain: { label: 'ABSTAIN', cls: 'border-white/15 bg-white/5 text-wtp-cream/60' },
  absent:  { label: 'ABSENT',  cls: 'border-white/15 bg-white/5 text-wtp-cream/40' },
};
const v = voteMeta[vote] ?? voteMeta.absent;

const directionMeta = directionRelativeToPlatform === 'with'
  ? { label: 'With WTP-PA platform', cls: 'text-wtp-sky' }
  : directionRelativeToPlatform === 'against'
    ? { label: 'Against WTP-PA platform', cls: 'text-wtp-red' }
    : { label: billAlignment === 'mixed' ? 'Bill is mixed alignment' : billAlignment === 'under-review' ? 'Bill not yet reviewed' : 'Vote not scorable', cls: 'text-wtp-cream/40' };

const formatDate = (iso: string) =>
  new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
    .format(new Date(iso + 'T00:00:00'));
---

<div class="flex flex-col gap-2 rounded-md border border-white/10 bg-surface/40 p-4 md:flex-row md:items-center md:gap-4">
  <span class={`flex-shrink-0 self-start rounded-md border px-2.5 py-1 text-center font-mono text-xs font-bold ${v.cls} md:w-20`}>
    {v.label}
  </span>
  <div class="min-w-0 flex-1">
    <div class="flex flex-wrap items-baseline gap-x-2 text-xs text-wtp-cream/50">
      <span class="font-mono font-semibold text-wtp-cream/70">{billId}</span>
      <span>·</span>
      <span>{formatDate(date)}</span>
    </div>
    <div class="mt-0.5 text-sm font-medium text-white">
      {billUrl ? <a href={billUrl} target="_blank" rel="noopener noreferrer" class="hover:text-wtp-sky">{billTitle}</a> : billTitle}
    </div>
    <div class={`mt-1 text-xs ${directionMeta.cls}`}>{directionMeta.label}</div>
  </div>
</div>
