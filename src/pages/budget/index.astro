---
import { config } from '../../config';
import projections from '../../../data/projections.json';
import keyStats from '../../../data/key-stats.json';
import population from '../../../data/population.json';
import revenueSources from '../../../data/revenue-sources.json';
import spendingByCategory from '../../../data/spending-by-category.json';
import rescueDoc from '../../../data/rescue-proposals.json';
import DeficitClock from '../../components/DeficitClock';
import PersonalImpactCalculator from '../../components/PersonalImpactCalculator';
import RainyDayCountdown from '../../components/RainyDayCountdown';
import RescuePlan from '../../components/RescuePlan';
import BudgetBreakdown from '../../components/BudgetBreakdown.astro';
import IFOPublications from '../../components/IFOPublications.astro';
import FederalContext from '../../components/FederalContext.astro';
import FederalCliffScenarios from '../../components/FederalCliffScenarios.astro';
import ShareRow from '../../components/ShareRow.astro';
import DashboardNav from '../../components/shared/DashboardNav.astro';
import SupportTipCTA from '../../components/shared/SupportTipCTA.astro';
import '../../styles/global.css';

const currentFY = projections.projections.find((p) => p.fiscalYear === '2025-26');
const annualDeficit = currentFY?.structuralDeficitUSD ?? 3_900_000_000;

const stat = (key: string) => keyStats.stats.find((s) => s.key === key);
const familyShare = stat('deficitPerFamilyOf4USD');
const rainyDayBalance = stat('rainyDayFundBalanceUSD');
const medicaid = stat('medicaidGrowthSince2018');
const reserves = stat('schoolDistrictReservesUSD');

const baseFamilyShareUSD = typeof familyShare?.value === 'number' ? familyShare.value : 1500;
const rainyDayUSD = typeof rainyDayBalance?.value === 'number' ? rainyDayBalance.value : 7_000_000_000;

const annualB = (annualDeficit / 1e9).toFixed(1);
const gapB = ((spendingByCategory.totalUSD - revenueSources.totalUSD) / 1e9).toFixed(1);

const pageTitle = `${config.project.name} — ${config.party.shortName}`;
const pageDescription = `Pennsylvania faces a $${annualB}B structural deficit. Track it in real time. Built by ${config.party.shortName}.`;
const siteOrigin = Astro.site ?? Astro.url;
const ogImageUrl = new URL(config.brand.ogImagePath, siteOrigin).toString();
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body class="min-h-screen bg-page text-white">
    <header>
      <div class="border-b border-white/10 px-6 py-4">
        <div class="mx-auto flex max-w-6xl items-center justify-between gap-4">
          <div class="flex min-w-0 flex-shrink-0 items-center gap-3">
            <a href="/" class="flex-shrink-0 hover:opacity-80 transition" aria-label="All dashboards">
              <img src={config.brand.logoPath} alt={`${config.party.shortName} logo`} class="h-10 w-auto sm:h-12" />
            </a>
            <div class="min-w-0 truncate text-base font-semibold sm:text-lg">{config.project.name}</div>
          </div>
          <div class="hidden md:flex md:flex-1 md:justify-center">
            <DashboardNav activeSlug="budget" />
          </div>
          <a href={config.party.website} class="flex-shrink-0 text-sm text-wtp-cream/70 no-underline hover:text-wtp-sky">
            wtpppa.org →
          </a>
        </div>
      </div>
      <div class="border-b border-white/10 bg-white/[0.02] px-6 py-2 md:hidden">
        <DashboardNav activeSlug="budget" />
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-6 pt-8 md:pt-12 pb-16 md:pb-24">
      <section>
        <p class="text-center text-xs uppercase tracking-[0.2em] text-wtp-sky">
          Pennsylvania's structural deficit
        </p>
        <h1 class="sr-only">Pennsylvania Structural Deficit Counter</h1>
        <div class="mt-8">
          <DeficitClock
            client:load
            fiscalYear="2025-26"
            annualDeficitUSD={annualDeficit}
          />
        </div>
        <ShareRow
          url={canonicalUrl}
          tweetText={`Pennsylvania has a $${annualB} billion structural deficit — and growing. Tracked live by ${config.party.shortName}.`}
        />
        <p class="mt-4 text-center text-sm">
          <a href="/budget/about" class="text-wtp-sky/80 no-underline hover:text-wtp-sky">About this dashboard →</a>
        </p>
      </section>

      <section class="mt-16" id="how-it-works">
        <h2 class="text-3xl font-extrabold md:text-4xl">How Pennsylvania's money works</h2>
        <p class="mt-6 max-w-3xl text-base leading-relaxed text-wtp-cream/80">
          The <strong class="text-white">General Fund</strong> is the state's main operating budget. Each year it collects about <strong class="text-white">$45 billion</strong> — almost entirely from income and sales taxes paid by working Pennsylvanians — and spends about <strong class="text-white">$50 billion</strong> on services, mostly Medicaid and education.
        </p>

        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          <BudgetBreakdown
            title="Where the money comes from"
            totalUSD={revenueSources.totalUSD}
            fiscalYear={revenueSources.fiscalYear}
            segments={revenueSources.sources}
            source={revenueSources.source.primary}
          />
          <BudgetBreakdown
            title="Where the money goes"
            totalUSD={spendingByCategory.totalUSD}
            fiscalYear={spendingByCategory.fiscalYear}
            segments={spendingByCategory.categories}
            source={spendingByCategory.source.primary}
          />
        </div>

        <p class="mt-10 max-w-3xl text-base leading-relaxed text-wtp-cream/80">
          The <strong class="text-wtp-red">~${gapB} billion gap</strong> between what comes in and what goes out is the structural deficit ticking above. It's projected to grow to <strong class="text-white">$6.7 billion</strong> next year and <strong class="text-white">$8.4 billion</strong> by FY 2029-30 if nothing changes.
        </p>

        <aside class="mt-10 max-w-3xl rounded-lg border border-wtp-gold/30 bg-wtp-gold/5 p-5 text-sm leading-relaxed text-wtp-cream/80">
          <div class="text-xs uppercase tracking-[0.18em] text-wtp-gold">Wait — what about property tax?</div>
          <p class="mt-2">
            Pennsylvania property taxes don't appear above because they aren't <em>state</em> revenue. PA is one of the few states where property tax is collected and spent entirely by <strong class="text-white">local government</strong> — school districts (the largest share), counties, and municipalities — and never enters the state General Fund. That's why a Pennsylvanian can pay one of the highest property tax burdens in the country and still see a state-level structural deficit. Property tax reform is in <a href={`${config.party.website}/platform`} class="text-wtp-sky underline">our platform</a> — but the fix happens at the local and state-policy level, not in the state's revenue mix.
          </p>
        </aside>
      </section>

      <section class="mt-24">
        <h2 class="text-3xl font-extrabold md:text-4xl">Paths to close the gap</h2>
        <p class="mt-6 max-w-3xl text-base leading-relaxed text-wtp-cream/80">
          The deficit isn't fate. There are real proposals on the table — some blocked, some pre-bill — that would generate billions in new revenue without raising taxes on working Pennsylvanians. Toggle each below to build your own plan and watch the gap close.
        </p>
        <div class="mt-8">
          <RescuePlan
            client:load
            proposals={rescueDoc.proposals as any}
            annualDeficitUSD={rescueDoc.annualDeficitUSD}
          />
        </div>
      </section>

      <section class="mt-24">
        <FederalContext />
      </section>

      <section class="mt-12 overflow-hidden rounded-lg border border-wtp-sky/20 bg-gradient-to-br from-wtp-navy/60 to-wtp-indigo/40 p-8 text-center md:p-14">
        <p class="text-xs uppercase tracking-[0.25em] text-wtp-sky">Empowering People · Restoring Trust</p>
        <h2 class="mt-4 text-3xl font-extrabold leading-tight md:text-4xl">
          Want a state government that earns your trust?
        </h2>
        <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-wtp-cream/90 md:text-lg">
          We The People Party of Pennsylvania believes accountability requires data, not slogans. If you want a different kind of state party — one that shows you the numbers and follows through — become a member.
        </p>
        <a
          href="https://www.wtpppa.org/membership"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-block rounded-md bg-wtp-sky px-8 py-4 text-sm font-bold uppercase tracking-[0.18em] text-wtp-navy no-underline transition hover:bg-wtp-cream"
        >
          Become a Member →
        </a>
      </section>

      <section class="mt-12">
        <FederalCliffScenarios />
      </section>

      <section class="mt-20 grid gap-6 md:grid-cols-3">
        <div class="rounded-lg border border-white/10 bg-surface p-6">
          <div class="text-3xl font-bold text-wtp-red">${familyShare?.value ?? '—'}</div>
          <div class="mt-2 text-sm text-wtp-cream/70">{familyShare?.label}</div>
          <div class="mt-3 text-xs text-wtp-cream/40">{familyShare?.source}</div>
        </div>
        <div class="rounded-lg border border-white/10 bg-surface p-6">
          <div class="text-3xl font-bold text-wtp-red">{medicaid?.value}</div>
          <div class="mt-2 text-sm text-wtp-cream/70">{medicaid?.label}</div>
          <div class="mt-3 text-xs text-wtp-cream/40">{medicaid?.source}</div>
        </div>
        <div class="rounded-lg border border-white/10 bg-surface p-6">
          <div class="text-3xl font-bold text-wtp-sky">$6.78B</div>
          <div class="mt-2 text-sm text-wtp-cream/70">{reserves?.label} sitting unused</div>
          <div class="mt-3 text-xs text-wtp-cream/40">{reserves?.source}</div>
        </div>
      </section>

      <section class="mt-12 grid items-start gap-6 lg:grid-cols-3">
        <div class="lg:col-span-2">
          <PersonalImpactCalculator
            client:visible
            baseFamilyShareUSD={baseFamilyShareUSD}
            totalDeficitUSD={annualDeficit}
            totalHouseholds={population.households}
          />
        </div>
        <RainyDayCountdown
          client:visible
          depletionDateISO="2027-06-30"
          rainyDayBalanceUSD={rainyDayUSD}
        />
      </section>

      <section class="mt-20">
        <IFOPublications />
      </section>
    </main>

    <SupportTipCTA />

    <footer class="border-t border-white/10 px-6 py-8 text-sm text-wtp-cream/60">
      <div class="mx-auto flex max-w-6xl flex-col gap-3 md:flex-row md:justify-between">
        <div>Built by {config.party.name}</div>
        <div class="flex gap-4">
          <a href="/budget/about" class="hover:text-white">About</a>
          <a href={config.party.website} class="hover:text-white">wtpppa.org</a>
          <a href={config.party.socials.twitter} class="hover:text-white">X</a>
          <a href={config.party.socials.facebook} class="hover:text-white">Facebook</a>
        </div>
      </div>
    </footer>
  </body>
</html>
