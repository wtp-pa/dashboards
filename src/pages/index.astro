---
import { config } from '../config';
import projections from '../../data/projections.json';
import BrandShortName from '../components/BrandShortName.astro';
import DashboardNav from '../components/shared/DashboardNav.astro';
import SupportTipCTA from '../components/shared/SupportTipCTA.astro';
import '../styles/global.css';

const currentFY = projections.projections.find((p) => p.fiscalYear === '2025-26');
const annualDeficitB = currentFY ? (currentFY.structuralDeficitUSD / 1e9).toFixed(1) : '3.9';

const pageTitle = `${config.portfolio.name}`;
const pageDescription = `${config.portfolio.tagline}. Built by ${config.party.name}.`;
const siteOrigin = Astro.site ?? Astro.url;
const ogImageUrl = new URL(config.brand.ogImagePath, siteOrigin).toString();
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body class="min-h-screen bg-page text-white">
    <header>
      <div class="border-b border-white/10 px-6 py-4">
        <div class="mx-auto flex max-w-6xl items-center justify-between gap-4">
          <div class="flex min-w-0 items-center gap-3">
            <img src={config.brand.logoPath} alt={`${config.party.shortName} logo`} class="h-10 w-auto flex-shrink-0 sm:h-12" />
            <div class="min-w-0 leading-tight">
              <div class="truncate text-base font-semibold sm:text-lg">
                <BrandShortName primaryClass="text-white" accentClass="text-wtp-gold" /> Dashboards
              </div>
            </div>
          </div>
          <a
            href={config.party.website}
            class="flex-shrink-0 text-sm text-wtp-cream/70 no-underline hover:text-wtp-sky"
          >
            wtpppa.org →
          </a>
        </div>
      </div>
      <DashboardNav />
    </header>

    <main class="mx-auto max-w-6xl px-6 pt-8 md:pt-12 pb-16 md:pb-24">
      <section class="text-center">
        <p class="text-xs uppercase tracking-[0.2em] text-wtp-sky">{config.portfolio.tagline}</p>
        <h1 class="mt-4 text-4xl font-extrabold leading-tight md:text-6xl">
          Pennsylvania Watch
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-wtp-cream/70 md:text-lg">
          A growing collection of tools for tracking how Pennsylvania's government spends money, who votes for what, and what it all means for everyday Pennsylvanians.
        </p>
      </section>

      <section class="mt-16 grid gap-6 md:grid-cols-2">
        {config.portfolio.projects.map((project) => {
          const status = project.status as 'live' | 'pre-release' | 'coming-soon';
          const isOpenable = status === 'live' || status === 'pre-release';
          const href = isOpenable ? `/${project.slug}` : null;
          const cardClasses = `rounded-lg border p-8 transition ${
            status === 'live'
              ? 'border-white/15 bg-surface hover:border-wtp-sky/50 hover:bg-surface/80'
              : status === 'pre-release'
                ? 'border-wtp-gold/30 bg-surface hover:border-wtp-gold/60 hover:bg-surface/80'
                : 'border-white/5 bg-surface/40 opacity-60'
          }`;

          const badge = status === 'live'
            ? <span class="text-xs uppercase tracking-widest text-wtp-sky">Live</span>
            : status === 'pre-release'
              ? <span class="rounded-full border border-wtp-gold/40 bg-wtp-gold/10 px-2.5 py-0.5 text-[10px] uppercase tracking-widest text-wtp-gold">Pre-release</span>
              : <span class="text-xs uppercase tracking-widest text-wtp-cream/40">Coming soon</span>;

          const Inner = (
            <>
              <div class="flex items-baseline justify-between gap-3">
                <h3 class="text-2xl font-bold">{project.name}</h3>
                {badge}
              </div>
              <p class="mt-3 text-sm leading-relaxed text-wtp-cream/70">{project.tagline}</p>
              {project.slug === 'budget' && status === 'live' && (
                <p class="mt-4 font-mono text-xl font-bold text-wtp-red">${annualDeficitB}B and growing</p>
              )}
              {project.slug === 'legislation' && status === 'pre-release' && (
                <p class="mt-4 text-xs italic text-wtp-cream/50">Awaiting officer review · usable now</p>
              )}
              {project.slug === 'elected-officials' && status === 'pre-release' && (
                <p class="mt-4 text-xs italic text-wtp-cream/50">Awaiting officer review · usable now · 251 legislators tracked</p>
              )}
              {isOpenable && (
                <p class="mt-6 text-sm text-wtp-sky">Open dashboard →</p>
              )}
            </>
          );

          return href ? (
            <a href={href} class={cardClasses}>{Inner}</a>
          ) : (
            <div class={cardClasses}>{Inner}</div>
          );
        })}
      </section>

      <section class="mt-24 overflow-hidden rounded-lg border border-wtp-sky/20 bg-gradient-to-br from-wtp-navy/60 to-wtp-indigo/40 p-8 text-center md:p-14">
        <p class="text-xs uppercase tracking-[0.25em] text-wtp-sky">Empowering People · Restoring Trust</p>
        <h2 class="mt-4 text-3xl font-extrabold leading-tight md:text-4xl">
          Like what you see? Help build it.
        </h2>
        <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-wtp-cream/90 md:text-lg">
          We The People Party of Pennsylvania believes accountability requires data, not slogans. If you want a different kind of state party — one that actually shows you the numbers — become a member.
        </p>
        <a
          href="https://www.wtpppa.org/membership"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-block rounded-md bg-wtp-sky px-8 py-4 text-sm font-bold uppercase tracking-[0.18em] text-wtp-navy no-underline transition hover:bg-wtp-cream"
        >
          Become a Member →
        </a>
      </section>
    </main>

    <SupportTipCTA />

    <footer class="border-t border-white/10 px-6 py-8 text-sm text-wtp-cream/60">
      <div class="mx-auto flex max-w-6xl flex-col gap-3 md:flex-row md:justify-between">
        <div>Built by {config.party.name}</div>
        <div class="flex gap-4">
          <a href={config.party.website} class="hover:text-white">wtpppa.org</a>
          <a href={config.party.socials.twitter} class="hover:text-white">X</a>
          <a href={config.party.socials.facebook} class="hover:text-white">Facebook</a>
        </div>
      </div>
    </footer>
  </body>
</html>
