---
import '../../styles/global.css';
import { config } from '../../config';
import OfficialCard from '../../components/elected-officials/OfficialCard.astro';
import DemoBanner from '../../components/elected-officials/DemoBanner.astro';
import officialsDoc from '../../../data/elected-officials/officials.json';
import scorecardsDoc from '../../../data/elected-officials/scorecards.json';
import zipDoc from '../../../data/elected-officials/zip-districts.json';
import countyPopDoc from '../../../data/elected-officials/county-populations.json';
import billsDoc from '../../../data/legislation/bills.json';
import platform from '../../../data/legislation/platform.json';
import { stageOf, STAGE_LABELS } from '../../lib/bills';

type PillarBreakdown = {
  pillarId: string;
  pillarName: string;
  withPlatform: number;
  againstPlatform: number;
  noted?: number;
  primarySponsor?: number;
  cosponsor?: number;
};
type Scorecard = {
  officialId: string;
  totalVotes: number;
  scorableVotes: number;
  withPlatform: number;
  againstPlatform: number;
  alignmentRate: number | null;
  byPillar?: PillarBreakdown[];
  billsSponsored?: { primary: number; cosponsor: number; touchingPlatform: number };
};

const scorecards = scorecardsDoc.scorecards as Scorecard[];
const scorecardById = new Map(scorecards.map((s) => [s.officialId, s]));

const officials = officialsDoc.officials.map((o) => {
  const sc = scorecardById.get(o.id);
  return {
    ...o,
    alignmentRate: sc?.alignmentRate ?? null,
    scorableVotes: sc?.scorableVotes ?? 0,
    totalVotes: sc?.totalVotes ?? 0,
    byPillar: sc?.byPillar ?? [],
    billsSponsored: sc?.billsSponsored ?? { primary: 0, cosponsor: 0, touchingPlatform: 0 },
  };
});

// Sort by sponsorship activity descending — that's the strongest "what they
// care about" signal. Tie-break by primary count, then alignment rate.
const sortedOfficials = [...officials].sort((a, b) => {
  const aTouching = a.billsSponsored.touchingPlatform;
  const bTouching = b.billsSponsored.touchingPlatform;
  if (bTouching !== aTouching) return bTouching - aTouching;
  const aPrimary = a.billsSponsored.primary;
  const bPrimary = b.billsSponsored.primary;
  if (bPrimary !== aPrimary) return bPrimary - aPrimary;
  if (a.alignmentRate === null && b.alignmentRate === null) return 0;
  if (a.alignmentRate === null) return 1;
  if (b.alignmentRate === null) return -1;
  return b.alignmentRate - a.alignmentRate;
});

// All 67 PA counties for the dropdown. Driven by county-populations.json
// so users can pick any county; for counties without hand-tagged
// officials, the lookup falls back to geocoding "X County, PA" via the
// Census API and hitting OpenStates /people.geo at the centroid.
const countyOptions = Object.keys(countyPopDoc.populations).sort();

// Filter pill counts — shown in the button labels so users can see at a
// glance how many of each chamber / party we track.
const chamberCounts = {
  all: officials.length,
  Senate: officials.filter((o) => o.chamber === 'Senate').length,
  House: officials.filter((o) => o.chamber === 'House').length,
};
const partyCounts: Record<string, number> = { all: officials.length };
for (const o of officials) {
  partyCounts[o.party] = (partyCounts[o.party] ?? 0) + 1;
}

const districtToOfficial: Record<string, { id: string; name: string; chamber: string }[]> = {};
for (const o of officials) {
  if (!o.district) continue;
  (districtToOfficial[o.district] ||= []).push({ id: o.id, name: o.name, chamber: o.chamber });
}

const pageTitle = `PA Elected Officials Watch — ${config.party.shortName}`;
const pageDescription = `How Pennsylvania legislators vote — and how their votes line up with the WTP-PA platform. Search by ZIP code or county.`;
const canonicalUrl = `${config.portfolio.baseUrl}/elected-officials/`;
const ogImageUrl = `${config.portfolio.baseUrl}${config.brand.ogImagePath}`;
const projectName = 'PA Elected Officials Watch';

// Inline payloads for the client-side lookup. Tiny JSON, no extra fetch.
const zipPayload = JSON.stringify(zipDoc.zips);
const districtPayload = JSON.stringify(districtToOfficial);
const countyPopPayload = JSON.stringify(countyPopDoc.populations);
// Index officials by their OpenStates ID so the geolocation lookup
// (which returns ocd-person/... IDs from OpenStates' /people.geo) can
// JOIN back to our card metadata.
const officialsByOcdId: Record<string, { id: string; name: string; chamber: string; district: string; party: string }> = {};
for (const o of officials) {
  const ocd = (o as { openstatesId?: string | null }).openstatesId;
  if (ocd) officialsByOcdId[ocd] = { id: o.id, name: o.name, chamber: o.chamber, district: o.district, party: o.party };
}
const officialsByOcdPayload = JSON.stringify(officialsByOcdId);
const openstatesApiKey = import.meta.env.PUBLIC_OPENSTATES_API_KEY ?? '';
// Build a county → list of officials map (server-side; client uses it for
// county area explainer). Mirrors the lookup logic but keyed by county.
const countyToOfficial: Record<string, { id: string; name: string; chamber: string; district: string; party: string }[]> = {};
for (const o of officials) {
  for (const c of o.counties ?? []) {
    (countyToOfficial[c] ||= []).push({ id: o.id, name: o.name, chamber: o.chamber, district: o.district, party: o.party });
  }
}
const countyOfficialPayload = JSON.stringify(countyToOfficial);

// Aggregate "what the General Assembly has actually been doing" stats —
// derived from bills.json so they auto-update with every cron run.
const allBills = billsDoc.bills as Array<{
  id: string;
  title: string;
  status: string;
  matches: Array<{ positionId: string }>;
}>;
const totalBillsFiled = allBills.length;
const billsByStage = allBills.reduce((acc, b) => {
  const stage = stageOf(b.status);
  acc[stage] = (acc[stage] ?? 0) + 1;
  return acc;
}, {} as Record<string, number>);
const billsBecameLaw = billsByStage['signed'] ?? 0;
const billsPastCommittee = (billsByStage['on-floor'] ?? 0) + (billsByStage['passed'] ?? 0) + billsBecameLaw;
const billsTouchingPlatform = allBills.filter((b) => b.matches.length > 0).length;

// Top pillars by bill count across the whole session.
const pillarById = Object.fromEntries(
  platform.pillars.map((p) => [p.id, { name: p.name, count: 0 }]),
);
const positionToPillar = new Map<string, string>();
for (const pillar of platform.pillars) {
  for (const pos of pillar.positions) positionToPillar.set(pos.id, pillar.id);
}
for (const bill of allBills) {
  const seenPillars = new Set<string>();
  for (const m of bill.matches) {
    const pid = positionToPillar.get(m.positionId);
    if (pid && !seenPillars.has(pid)) {
      seenPillars.add(pid);
      pillarById[pid].count += 1;
    }
  }
}
const topPillars = Object.entries(pillarById)
  .map(([id, v]) => ({ id, name: v.name, count: v.count }))
  .filter((p) => p.count > 0)
  .sort((a, b) => b.count - a.count)
  .slice(0, 5);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/wtp-logo.png" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body class="min-h-screen bg-page text-white">
    <DemoBanner />

    <header class="border-b border-white/10 px-6 py-4">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 md:grid md:grid-cols-3">
        <a href="/" class="flex min-w-0 items-center gap-3 hover:opacity-80 transition md:justify-self-start">
          <img src={config.brand.logoPath} alt="WTP-PA logo" class="h-10 w-auto flex-shrink-0 sm:h-12" />
          <div class="min-w-0 truncate text-base font-semibold sm:text-lg">{projectName}</div>
        </a>
        <a href={config.party.website} class="hidden text-center text-sm text-wtp-cream/70 no-underline hover:text-wtp-sky md:block md:justify-self-center">
          {config.party.name}
        </a>
        <nav class="flex flex-shrink-0 items-center gap-4 text-sm md:justify-self-end">
          <a href="/legislation/" class="text-wtp-cream/70 no-underline hover:text-wtp-sky">Bills</a>
          <a href="/legislation/about/" class="text-wtp-cream/70 no-underline hover:text-wtp-sky">Methodology</a>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-6 py-12 md:py-16">
      <section>
        <p class="text-xs uppercase tracking-[0.2em] text-wtp-sky">Accountability for the people we voted for</p>
        <h1 class="mt-4 text-4xl font-extrabold leading-tight md:text-6xl">PA Elected Officials Watch</h1>
        <p class="mt-6 max-w-3xl text-base leading-relaxed text-wtp-cream/80 md:text-lg">
          Every vote on a {config.party.shortName}-reviewed bill is scored against our <a href={`${config.party.website}/platform`} class="text-wtp-sky underline">platform</a>. We show you who votes <em>with</em> the platform, who votes <em>against</em>, and which pillar each vote touches. Powered by the same matcher behind <a href="/legislation/" class="text-wtp-sky underline">Legislation Watch</a>.
        </p>
      </section>

      <details class="group mt-10 rounded-lg border border-wtp-sky/30 bg-wtp-sky/5 transition hover:border-wtp-sky/50">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-3 p-5 md:p-6">
          <div class="min-w-0">
            <h2 class="text-base font-semibold text-white">New here? Tap to read a 90-second primer on PA government</h2>
            <p class="mt-1 text-xs text-wtp-cream/70">Who these people are, what they decide, what's <em>not</em> their job (Congress and local government handle those instead), and the difference between a state senator and a state rep.</p>
          </div>
          <div class="flex flex-shrink-0 items-center gap-2 text-xs font-semibold uppercase tracking-wider text-wtp-sky">
            <span class="group-open:hidden">Read</span>
            <span class="hidden group-open:inline">Hide</span>
            <span class="grid h-8 w-8 place-items-center rounded-full border border-wtp-sky/40 bg-wtp-sky/10 text-base font-bold transition group-open:rotate-180" aria-hidden="true">▾</span>
          </div>
        </summary>
        <div class="space-y-5 border-t border-wtp-sky/20 px-5 pb-5 pt-4 text-sm leading-relaxed text-wtp-cream/85 md:px-6 md:pb-6">
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <h3 class="text-xs uppercase tracking-wider text-wtp-sky">State legislature ≠ Congress</h3>
              <p class="mt-1">
                The U.S. Congress (Senate + House) makes <em>federal</em> law in Washington D.C. — same laws for all 50 states.
                The <strong class="text-white">Pennsylvania General Assembly</strong> is separate. It makes laws that apply only to PA. Most laws that touch your day-to-day life are state laws, not federal.
              </p>
            </div>
            <div>
              <h3 class="text-xs uppercase tracking-wider text-wtp-sky">PA's two chambers</h3>
              <ul class="mt-1 space-y-1.5">
                <li><strong class="text-white">Senate:</strong> 50 members · 4-year terms · staggered (half elected every 2 years)</li>
                <li><strong class="text-white">House of Representatives:</strong> 203 members · 2-year terms (all elected every 2 years)</li>
                <li>Total: <strong class="text-white">253 state legislators</strong>, all in Harrisburg.</li>
              </ul>
            </div>
          </div>

          <div>
            <h3 class="text-xs uppercase tracking-wider text-wtp-sky">Important: you're represented by district, not county</h3>
            <p class="mt-1 text-xs text-wtp-cream/85">
              Your county doesn't elect your reps — your <strong class="text-white">district</strong> does. PA Senate districts cover ~260,000 people each; House districts ~64,000. Most counties span multiple districts:
            </p>
            <ul class="mt-2 space-y-1 text-xs text-wtp-cream/75">
              <li><strong class="text-white">Chester County (534k people)</strong> → ~2 Senators + ~8 Reps overlap it (different streets get different reps)</li>
              <li><strong class="text-white">Allegheny (1.25M)</strong> → ~5 Senators + ~20 Reps</li>
              <li><strong class="text-white">Philadelphia (1.6M)</strong> → ~6 Senators + ~25 Reps</li>
              <li><strong class="text-white">Sullivan (5,840)</strong> → 1 Senator + 1 Rep (only here is "the county's reps" a clean concept)</li>
            </ul>
            <p class="mt-2 text-xs text-wtp-cream/85">
              That's why the address input is the most accurate way to find your reps — same exact 1 Senator + 1 Rep that any address-level lookup gives, just for <em>your</em> address. Picking a county returns only the reps at the geographic center, which may be a different pair than yours.
            </p>
          </div>

          <div>
            <h3 class="text-xs uppercase tracking-wider text-wtp-sky">Senator vs Representative — what's the difference?</h3>
            <p class="mt-1 text-xs text-wtp-cream/60">PA has both because the General Assembly is <em>bicameral</em> — every bill must pass both chambers to become law, designed as a check against either house acting alone.</p>
            <div class="mt-3 grid gap-3 md:grid-cols-2">
              <div class="rounded-md border border-white/10 bg-white/5 p-3">
                <div class="text-[11px] font-semibold uppercase tracking-wider text-wtp-sky">State Senator</div>
                <ul class="mt-2 space-y-1 text-xs text-wtp-cream/85">
                  <li><strong class="text-white">50 senators total</strong> — one per Senate district (SD-1 to SD-50)</li>
                  <li><strong class="text-white">4-year terms</strong>, staggered (half elected every 2 years)</li>
                  <li><strong class="text-white">Larger districts</strong> — each represents ~260,000 people</li>
                  <li>Vote on confirmations of governor's appointments (judges, cabinet)</li>
                  <li>Often more deliberative; longer institutional memory</li>
                </ul>
              </div>
              <div class="rounded-md border border-white/10 bg-white/5 p-3">
                <div class="text-[11px] font-semibold uppercase tracking-wider text-wtp-sky">State Representative</div>
                <ul class="mt-2 space-y-1 text-xs text-wtp-cream/85">
                  <li><strong class="text-white">203 reps total</strong> — one per House district (HD-1 to HD-203)</li>
                  <li><strong class="text-white">2-year terms</strong>, all elected together every 2 years</li>
                  <li><strong class="text-white">Smaller districts</strong> — each represents ~64,000 people</li>
                  <li>Bills involving raising state revenue must originate in the House</li>
                  <li>Often closer to constituent issues; more turnover</li>
                </ul>
              </div>
            </div>
            <p class="mt-2 text-xs text-wtp-cream/60">
              You're represented by <strong class="text-white">one senator and one rep at the state level</strong>, plus your federal U.S. Senator and U.S. House Rep — four different elected officials.
            </p>
          </div>

          <div>
            <h3 class="text-xs uppercase tracking-wider text-wtp-sky">Who decides what — quick reference</h3>
            <p class="mt-1 text-xs text-wtp-cream/60">If you're frustrated about something, this is where to direct that frustration.</p>
            <div class="mt-3 grid gap-3 md:grid-cols-3">
              <div class="rounded-md border border-wtp-sky/30 bg-wtp-sky/5 p-3">
                <div class="text-[11px] font-semibold uppercase tracking-wider text-wtp-sky">PA General Assembly (these people)</div>
                <ul class="mt-2 space-y-1 text-xs text-wtp-cream/85">
                  <li>State income tax & corporate tax</li>
                  <li>Public school funding formula</li>
                  <li>Election rules (mail-in ballots, IDs, hours)</li>
                  <li>State criminal code & sentencing</li>
                  <li>Driver's licenses, vehicle code</li>
                  <li>State universities & community colleges</li>
                  <li>Medicaid expansion</li>
                  <li>Marijuana, alcohol, gambling laws</li>
                  <li>Healthcare provider licensing</li>
                  <li>State courts above the magistrate level</li>
                </ul>
              </div>
              <div class="rounded-md border border-white/15 bg-white/5 p-3">
                <div class="text-[11px] font-semibold uppercase tracking-wider text-wtp-cream/70">U.S. Congress (federal)</div>
                <ul class="mt-2 space-y-1 text-xs text-wtp-cream/75">
                  <li>Federal income tax</li>
                  <li>Social Security & Medicare</li>
                  <li>National defense, military</li>
                  <li>Immigration & citizenship</li>
                  <li>Interstate commerce regulation</li>
                  <li>Federal civil-rights laws</li>
                  <li>Federal courts</li>
                  <li>Postal service, currency</li>
                  <li>Trade agreements & tariffs</li>
                </ul>
              </div>
              <div class="rounded-md border border-white/15 bg-white/5 p-3">
                <div class="text-[11px] font-semibold uppercase tracking-wider text-wtp-cream/70">Local (county / city / township)</div>
                <ul class="mt-2 space-y-1 text-xs text-wtp-cream/75">
                  <li>Property tax rate (your bill)</li>
                  <li>School district policies & boards</li>
                  <li>Local zoning & permits</li>
                  <li>Police staffing & funding</li>
                  <li>Trash, water, snow removal</li>
                  <li>Local roads (not state highways)</li>
                  <li>Magistrate / district courts</li>
                  <li>County prisons, sheriff</li>
                </ul>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-xs uppercase tracking-wider text-wtp-sky">What does a legislator's day-to-day look like?</h3>
            <ul class="mt-2 grid gap-2 text-xs md:grid-cols-2">
              <li class="rounded-md bg-white/5 p-3"><strong class="text-white">Introduce bills.</strong> They write or co-write proposed laws. This is the strongest signal of priorities — a legislator chooses what to put their name on.</li>
              <li class="rounded-md bg-white/5 p-3"><strong class="text-white">Vote on bills.</strong> Yes/no on whatever reaches the floor. Most votes are on others' bills, often along party lines or on procedural details.</li>
              <li class="rounded-md bg-white/5 p-3"><strong class="text-white">Serve on committees.</strong> Committees decide which bills die and which advance. Subject-matter focus (Education, Judiciary, Health) reveals where they have influence.</li>
              <li class="rounded-md bg-white/5 p-3"><strong class="text-white">Constituent services.</strong> Help residents navigate the state — driver's license trouble, unemployment claims, getting a state agency to respond. Off-the-books but real.</li>
            </ul>
          </div>
        </div>
      </details>

      <details class="group mt-10 rounded-lg border border-white/10 bg-surface/40 transition hover:border-white/20">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-3 p-5 md:p-6">
          <div class="min-w-0 flex-1">
            <h2 class="text-base font-semibold text-white">What the General Assembly has been working on</h2>
            <p class="mt-1 flex flex-wrap gap-x-3 gap-y-0.5 text-xs text-wtp-cream/70">
              <span><strong class="text-white">{totalBillsFiled.toLocaleString()}</strong> bills introduced</span>
              <span class="text-wtp-cream/40">·</span>
              <span><strong class="text-wtp-sky">{billsTouchingPlatform.toLocaleString()}</strong> touch our platform</span>
              <span class="text-wtp-cream/40">·</span>
              <span><strong class="text-wtp-gold">{billsPastCommittee.toLocaleString()}</strong> past committee</span>
              <span class="text-wtp-cream/40">·</span>
              <span><strong class="text-white">{billsBecameLaw.toLocaleString()}</strong> signed</span>
            </p>
          </div>
          <div class="flex flex-shrink-0 items-center gap-2 text-xs font-semibold uppercase tracking-wider text-wtp-sky">
            <span class="group-open:hidden">Detail</span>
            <span class="hidden group-open:inline">Hide</span>
            <span class="grid h-8 w-8 place-items-center rounded-full border border-wtp-sky/40 bg-wtp-sky/10 text-base font-bold transition group-open:rotate-180" aria-hidden="true">▾</span>
          </div>
        </summary>
        <div class="border-t border-white/10 px-5 pb-5 pt-4 md:px-6 md:pb-6">
          <p class="text-sm text-wtp-cream/70">
            Aggregate output across all 253 PA legislators this session ({officialsDoc.session}). This is the universe of work — what your senator does is one slice of this.
          </p>

          <div class="mt-5 grid grid-cols-2 gap-3 text-sm md:grid-cols-4">
            <div class="rounded-md border border-white/10 bg-white/5 p-4">
              <div class="text-3xl font-bold text-white">{totalBillsFiled.toLocaleString()}</div>
              <div class="mt-1 text-xs uppercase tracking-wider text-wtp-cream/60">Bills introduced</div>
            </div>
            <div class="rounded-md border border-wtp-sky/30 bg-wtp-sky/5 p-4">
              <div class="text-3xl font-bold text-wtp-sky">{billsTouchingPlatform.toLocaleString()}</div>
              <div class="mt-1 text-xs uppercase tracking-wider text-wtp-cream/60">Touch our platform</div>
            </div>
            <div class="rounded-md border border-wtp-gold/30 bg-wtp-gold/5 p-4">
              <div class="text-3xl font-bold text-wtp-gold">{billsPastCommittee.toLocaleString()}</div>
              <div class="mt-1 text-xs uppercase tracking-wider text-wtp-cream/60">Made it past committee</div>
            </div>
            <div class="rounded-md border border-wtp-red/20 bg-wtp-red/5 p-4">
              <div class="text-3xl font-bold text-white">{billsBecameLaw.toLocaleString()}</div>
              <div class="mt-1 text-xs uppercase tracking-wider text-wtp-cream/60">Signed into law</div>
            </div>
          </div>

          {topPillars.length > 0 && (
            <div class="mt-6">
              <div class="text-[11px] uppercase tracking-wider text-wtp-cream/50">Most-introduced platform topics this session</div>
              <div class="mt-2 space-y-1.5">
                {topPillars.map((p) => {
                  const widthPct = Math.round((p.count / topPillars[0].count) * 100);
                  return (
                    <div class="flex items-center gap-3 text-xs">
                      <span class="w-32 flex-shrink-0 truncate text-wtp-cream/80">{p.name}</span>
                      <span class="relative h-2 flex-1 overflow-hidden rounded-full bg-white/5">
                        <span class="absolute inset-y-0 left-0 bg-wtp-sky" style={`width: ${widthPct}%`}></span>
                      </span>
                      <span class="w-16 flex-shrink-0 text-right font-mono text-wtp-cream/60">{p.count} bills</span>
                    </div>
                  );
                })}
              </div>
            </div>
          )}

          <p class="mt-5 text-xs text-wtp-cream/50">
            {Math.round((billsBecameLaw / totalBillsFiled) * 100) || 0}% of bills introduced this session have become law so far.
            Most die in committee — see <a href="/legislation/" class="text-wtp-sky underline">Legislation Watch</a> for which platform-touching bills are still alive.
          </p>
        </div>
      </details>

      <details open class="group mt-10 rounded-lg border border-wtp-sky/20 bg-surface/30 transition hover:border-wtp-sky/40">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-3 p-5 md:p-6">
          <div class="min-w-0">
            <h2 class="text-lg font-bold md:text-xl">Find your representatives</h2>
            <p class="mt-0.5 text-xs text-wtp-cream/60">Reps are elected by district, not county — type your address for the most accurate match.</p>
          </div>
          <div class="flex flex-shrink-0 items-center gap-2 text-xs font-semibold uppercase tracking-wider text-wtp-sky">
            <span class="group-open:hidden">Show</span>
            <span class="hidden group-open:inline">Hide</span>
            <span class="grid h-8 w-8 place-items-center rounded-full border border-wtp-sky/40 bg-wtp-sky/10 text-base font-bold transition group-open:rotate-180" aria-hidden="true">▾</span>
          </div>
        </summary>
        <div class="border-t border-wtp-sky/20 px-5 pb-5 pt-4 md:px-6 md:pb-6">

        <form id="address-form" class="flex flex-col gap-2 sm:flex-row sm:items-center" novalidate>
          <input
            type="text"
            id="address-input"
            placeholder="Street + town (e.g., 100 Market St, Harrisburg)"
            aria-label="Street address"
            class="min-w-0 flex-1 rounded-md border border-white/15 bg-page px-4 py-2.5 text-sm text-white placeholder:text-wtp-cream/40 focus:border-wtp-sky focus:outline-none"
          />
          <div class="flex gap-2">
            <button type="submit" class="flex-1 rounded-md bg-wtp-sky px-4 py-2.5 text-sm font-semibold text-wtp-navy transition hover:bg-wtp-sky/90 sm:flex-none">Find</button>
            <button type="button" id="geo-button" class="flex flex-shrink-0 items-center gap-1.5 rounded-md border border-wtp-sky/40 bg-wtp-sky/10 px-3 py-2.5 text-xs font-semibold text-wtp-sky transition hover:bg-wtp-sky/20" title="Use my location">
              <span aria-hidden="true">📍</span>
              <span class="hidden sm:inline">My location</span>
            </button>
          </div>
        </form>

        <details class="mt-3">
          <summary class="cursor-pointer text-xs text-wtp-cream/50 hover:text-wtp-cream/80">Don't have an address handy? Try by county or ZIP instead</summary>
          <div class="mt-3 space-y-3">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
              <span class="w-24 flex-shrink-0 text-xs uppercase tracking-wider text-wtp-cream/50">By county</span>
              <select
                id="county-select"
                aria-label="County"
                class="min-w-0 flex-1 rounded-md border border-white/15 bg-page px-3 py-2 text-sm text-white focus:border-wtp-sky focus:outline-none sm:max-w-xs"
              >
                <option value="">Pick a county…</option>
                {countyOptions.map((c) => <option value={c}>{c} County</option>)}
              </select>
            </div>
            <form id="zip-form" class="flex flex-col gap-2 sm:flex-row sm:items-center" novalidate>
              <span class="w-24 flex-shrink-0 text-xs uppercase tracking-wider text-wtp-cream/50">By ZIP</span>
              <input
                type="text"
                id="zip-input"
                inputmode="numeric"
                pattern="[0-9]{5}"
                maxlength="5"
                placeholder="e.g., 17109"
                aria-label="ZIP code"
                class="w-32 rounded-md border border-white/15 bg-page px-3 py-2 text-center font-mono text-sm text-white placeholder:text-wtp-cream/40 focus:border-wtp-sky focus:outline-none"
              />
              <button type="submit" class="flex-shrink-0 rounded-md bg-wtp-sky px-4 py-2 text-sm font-semibold text-wtp-navy transition hover:bg-wtp-sky/90">Find</button>
            </form>
            <p class="text-[11px] text-wtp-cream/40">Either lookup samples multiple points to catch every overlapping district. Address input above gives the most precise pair.</p>
          </div>
        </details>

        <p class="mt-3 text-[11px] text-wtp-cream/40">Address & location lookups geocode you privately (U.S. Census or OpenStreetMap), then OpenStates returns your reps. Nothing is logged.</p>

        <div id="lookup-result" class="mt-4 hidden rounded-md border border-wtp-sky/30 bg-wtp-sky/5 p-3 text-sm"></div>
        </div>
      </details>

      <section class="mt-14">
        <div class="flex flex-wrap items-baseline justify-between gap-3">
          <h2 class="text-2xl font-bold md:text-3xl">{officials.length} officials tracked</h2>
          <div class="text-xs text-wtp-cream/50">{officialsDoc.session}</div>
        </div>
        <p class="mt-2 text-sm text-wtp-cream/60">Sorted by platform-touching sponsorship activity. Click a card for the full vote-by-vote and bill-by-bill detail.</p>

        <div class="mt-6 rounded-lg border border-white/10 bg-surface/30 p-4 md:p-5">
          <div class="flex flex-col gap-3 md:flex-row md:items-center md:gap-4">
            <input
              type="search"
              id="name-filter"
              placeholder="Search by name…"
              aria-label="Search by name"
              class="min-w-0 flex-1 rounded-md border border-white/15 bg-page px-4 py-2 text-sm text-white placeholder:text-wtp-cream/40 focus:border-wtp-sky focus:outline-none"
            />
            <div class="flex flex-wrap gap-2" role="group" aria-label="Chamber filter">
              <button type="button" class="chamber-pill rounded-full border border-wtp-sky bg-wtp-sky px-3 py-1.5 text-xs font-medium text-wtp-navy transition" data-chamber="all" data-active="true">All chambers <span class="opacity-70">{chamberCounts.all}</span></button>
              <button type="button" class="chamber-pill rounded-full border border-white/20 px-3 py-1.5 text-xs font-medium text-wtp-cream/70 transition hover:border-wtp-sky hover:text-white" data-chamber="Senate">Senate <span class="opacity-70">{chamberCounts.Senate}</span></button>
              <button type="button" class="chamber-pill rounded-full border border-white/20 px-3 py-1.5 text-xs font-medium text-wtp-cream/70 transition hover:border-wtp-sky hover:text-white" data-chamber="House">House <span class="opacity-70">{chamberCounts.House}</span></button>
            </div>
            <div class="flex flex-wrap gap-2" role="group" aria-label="Party filter">
              <button type="button" class="party-pill rounded-full border border-wtp-sky bg-wtp-sky px-3 py-1.5 text-xs font-medium text-wtp-navy transition" data-party="all" data-active="true">All parties <span class="opacity-70">{partyCounts.all}</span></button>
              <button type="button" class="party-pill rounded-full border border-white/20 px-3 py-1.5 text-xs font-medium text-wtp-cream/70 transition hover:border-wtp-sky hover:text-white" data-party="D">D <span class="opacity-70">{partyCounts.D ?? 0}</span></button>
              <button type="button" class="party-pill rounded-full border border-white/20 px-3 py-1.5 text-xs font-medium text-wtp-cream/70 transition hover:border-wtp-sky hover:text-white" data-party="R">R <span class="opacity-70">{partyCounts.R ?? 0}</span></button>
              {(partyCounts.I ?? 0) > 0 && (
                <button type="button" class="party-pill rounded-full border border-white/20 px-3 py-1.5 text-xs font-medium text-wtp-cream/70 transition hover:border-wtp-sky hover:text-white" data-party="I">I <span class="opacity-70">{partyCounts.I}</span></button>
              )}
            </div>
          </div>
          <div class="mt-3 flex items-center justify-between text-xs text-wtp-cream/60">
            <div><span id="visible-count">{officials.length}</span> visible</div>
            <button type="button" id="reset-filters" class="text-wtp-sky underline-offset-2 hover:underline">Reset filters</button>
          </div>
        </div>

        <details class="group mt-5 rounded-md border border-white/10 bg-white/5 transition hover:border-white/20">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-3">
            <span class="text-sm font-semibold text-white">How to read a legislator's card</span>
            <span class="flex flex-shrink-0 items-center gap-2 text-[11px] font-semibold uppercase tracking-wider text-wtp-sky">
              <span class="group-open:hidden">Show</span>
              <span class="hidden group-open:inline">Hide</span>
              <span class="grid h-7 w-7 place-items-center rounded-full border border-wtp-sky/40 bg-wtp-sky/10 text-sm font-bold transition group-open:rotate-180" aria-hidden="true">▾</span>
            </span>
          </summary>
          <div class="border-t border-white/10 px-4 py-4 text-xs leading-relaxed text-wtp-cream/80 md:text-sm">
            <ul class="space-y-2">
              <li><strong class="text-white">Bills introduced (the big number)</strong> = how many bills this legislator put their own name on as primary sponsor this session. Strongest "what they care about" signal — they chose to write or champion these.</li>
              <li><strong class="text-white">+ N cosponsor</strong> = bills others introduced that this legislator signed onto. Weaker signal but still topical interest.</li>
              <li><strong class="text-white">"X of N touch our platform"</strong> = how many of their sponsored bills match a {config.party.shortName} platform pillar. Bills can sponsor a topic without aligning with our position — alignment lives in <a href="/legislation/" class="text-wtp-sky underline">Legislation Watch</a>.</li>
              <li><strong class="text-white">Most-sponsored pillars (mini bars)</strong> = which platform topics they put their effort into. Solid sky bar = primary sponsor, faded sky = cosponsor.</li>
              <li><strong class="text-white">Voting record</strong> = how they voted on others' bills that reached a roll-call floor vote. Often along party lines or on procedural amendments — a weaker signal than what they sponsor. Will say "no scorable floor votes yet" if no platform-touching bills reached the floor on their watch.</li>
              <li><strong class="text-wtp-gold">Heads up:</strong> a high "sponsored" number isn't impact — many bills die in committee. Look for sponsorship <em>plus</em> committee progression on the detail page.</li>
            </ul>
          </div>
        </details>

        <div id="roster" class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {sortedOfficials.map((o) => (
            <div
              data-official-id={o.id}
              data-counties={(o.counties ?? []).join(',')}
              data-district={o.district}
              data-chamber={o.chamber}
              data-party={o.party}
              data-name={o.name.toLowerCase()}
            >
              <OfficialCard
                id={o.id}
                name={o.name}
                title={o.title}
                district={o.district}
                party={o.party}
                region={o.region}
                counties={o.counties}
                alignmentRate={o.alignmentRate}
                scorableVotes={o.scorableVotes}
                totalVotes={o.totalVotes}
                byPillar={o.byPillar}
                billsSponsored={o.billsSponsored}
                chamber={o.chamber}
                currentTermStart={(o as { currentTermStart?: number | null }).currentTermStart}
                currentTermEnd={(o as { currentTermEnd?: number | null }).currentTermEnd}
              />
            </div>
          ))}
        </div>
      </section>

      <section class="mt-20 rounded-lg border border-wtp-sky/20 bg-gradient-to-br from-wtp-navy/60 to-wtp-indigo/40 p-8 md:p-12">
        <p class="text-xs uppercase tracking-[0.25em] text-wtp-sky">{config.party.tagline}</p>
        <h2 class="mt-4 text-3xl font-extrabold leading-tight md:text-4xl">Want a state party that reads the votes?</h2>
        <p class="mt-5 max-w-2xl text-base leading-relaxed text-wtp-cream/90 md:text-lg">
          Most Pennsylvanians never see how their representatives actually voted on the bills that matter. We score every reviewed roll call against {config.party.shortName}'s platform so you can hold them accountable.
        </p>
        <div class="mt-6">
          <a href={config.party.website} class="inline-block rounded-md bg-wtp-sky px-6 py-3 text-sm font-semibold text-wtp-navy no-underline transition hover:bg-wtp-sky/90">
            Join {config.party.shortName} →
          </a>
        </div>
      </section>
    </main>

    <footer class="border-t border-white/10 px-6 py-8 text-xs text-wtp-cream/50">
      <div class="mx-auto flex max-w-6xl flex-col gap-3 md:flex-row md:justify-between">
        <div>Built by {config.party.name}</div>
        <div class="flex gap-4">
          <a href={config.party.website} class="hover:text-white">wtpppa.org</a>
          <a href={config.party.socials.twitter} class="hover:text-white">X</a>
          <a href={config.party.socials.facebook} class="hover:text-white">Facebook</a>
          <a href="/legislation/about/" class="hover:text-white">Methodology</a>
        </div>
      </div>
    </footer>

    <script is:inline define:vars={{ zipPayload, districtPayload, countyPopPayload, countyOfficialPayload, officialsByOcdPayload, openstatesApiKey }}>
      const zips = JSON.parse(zipPayload);
      const districtMap = JSON.parse(districtPayload);
      const countyPop = JSON.parse(countyPopPayload);
      const countyOfficials = JSON.parse(countyOfficialPayload);
      const officialsByOcd = JSON.parse(officialsByOcdPayload);
      const fmtNum = (n) => Number(n).toLocaleString();
      const resultEl = document.getElementById('lookup-result');
      const roster = document.getElementById('roster');
      const visibleCountEl = document.getElementById('visible-count');

      const filters = { name: '', chamber: 'all', party: 'all', highlightIds: null };

      function applyFilters() {
        const cards = roster.querySelectorAll('[data-official-id]');
        let visible = 0;
        cards.forEach((card) => {
          const matchesName = !filters.name || (card.dataset.name || '').includes(filters.name);
          const matchesChamber = filters.chamber === 'all' || card.dataset.chamber === filters.chamber;
          const matchesParty = filters.party === 'all' || card.dataset.party === filters.party;
          const matchesLookup = !filters.highlightIds || filters.highlightIds.includes(card.dataset.officialId);
          const isVisible = matchesName && matchesChamber && matchesParty && matchesLookup;
          card.classList.toggle('hidden', !isVisible);
          if (isVisible) visible++;
        });
        if (visibleCountEl) visibleCountEl.textContent = String(visible);
      }

      function setActivePill(pillClass, value) {
        document.querySelectorAll('.' + pillClass).forEach((btn) => {
          const isActive = btn.dataset[pillClass === 'chamber-pill' ? 'chamber' : 'party'] === value;
          btn.dataset.active = isActive ? 'true' : 'false';
          btn.classList.toggle('bg-wtp-sky', isActive);
          btn.classList.toggle('border-wtp-sky', isActive);
          btn.classList.toggle('text-wtp-navy', isActive);
          btn.classList.toggle('border-white/20', !isActive);
          btn.classList.toggle('text-wtp-cream/70', !isActive);
        });
      }

      document.getElementById('name-filter').addEventListener('input', (e) => {
        filters.name = (e.target.value || '').toLowerCase().trim();
        applyFilters();
      });

      document.querySelectorAll('.chamber-pill').forEach((btn) => {
        btn.addEventListener('click', () => {
          filters.chamber = btn.dataset.chamber;
          setActivePill('chamber-pill', filters.chamber);
          applyFilters();
        });
      });

      document.querySelectorAll('.party-pill').forEach((btn) => {
        btn.addEventListener('click', () => {
          filters.party = btn.dataset.party;
          setActivePill('party-pill', filters.party);
          applyFilters();
        });
      });

      document.getElementById('reset-filters').addEventListener('click', () => {
        filters.name = '';
        filters.chamber = 'all';
        filters.party = 'all';
        filters.highlightIds = null;
        document.getElementById('name-filter').value = '';
        document.getElementById('zip-input').value = '';
        document.getElementById('county-select').value = '';
        setActivePill('chamber-pill', 'all');
        setActivePill('party-pill', 'all');
        resultEl.classList.add('hidden');
        applyFilters();
      });

      function showResult(html) {
        resultEl.innerHTML = html;
        resultEl.classList.remove('hidden');
      }

      function highlightOfficials(ids) {
        // Lookup highlight — narrow the visible set rather than dimming.
        // Cleaner with 251 cards than the previous opacity ring approach.
        filters.highlightIds = ids.length ? ids : null;
        applyFilters();
        if (ids.length) {
          const first = roster.querySelector(`[data-official-id="${ids[0]}"]`);
          first?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }

      function renderAreaCard(opts) {
        // opts: { areaLabel, areaDetail, districts, reps, populationLine, footerNote }
        const districtsInline = opts.districts && opts.districts.length
          ? `<span class="text-xs text-wtp-cream/60"> · ${opts.districts.map((d) => `<span class="font-mono text-white">${d}</span>`).join(', ')}</span>`
          : '';
        const repsHtml = opts.reps && opts.reps.length
          ? `<div class="mt-2 flex flex-wrap gap-1.5">${opts.reps.map((r) =>
              `<a href="/elected-officials/${r.id}/" class="rounded-full border border-wtp-sky/40 bg-wtp-sky/10 px-2.5 py-0.5 text-xs text-wtp-sky no-underline transition hover:bg-wtp-sky hover:text-wtp-navy">${r.name} <span class="text-wtp-cream/60">· ${r.chamber} · ${r.district}</span></a>`
            ).join('')}</div>`
          : `<div class="mt-2 text-xs italic text-wtp-cream/60">${opts.noRepsMessage || 'No matching officials in our roster yet.'}</div>`;
        const popHtml = opts.populationLine
          ? ` <span class="text-xs text-wtp-cream/60">· ${opts.populationLine}</span>`
          : '';
        const footer = opts.footerNote
          ? `<div class="mt-2 text-[11px] leading-snug italic text-wtp-cream/50">${opts.footerNote}</div>`
          : '';
        // Federal-reps reminder so users don't think we're hiding their U.S.
        // Senators / Reps. Only show when we actually returned PA state reps —
        // would be confusing on empty/error cards.
        const federal = opts.reps && opts.reps.length
          ? `<div class="mt-2 text-[11px] text-wtp-cream/50">You're also represented federally by 2 U.S. Senators and 1 U.S. Representative — see <a href="https://www.congress.gov/members" target="_blank" rel="noopener" class="text-wtp-sky underline">congress.gov/members</a> for those.</div>`
          : '';
        showResult(`
          <div class="flex flex-wrap items-baseline gap-x-2 text-sm">
            <span class="text-[10px] uppercase tracking-wider text-wtp-sky">${opts.areaLabel}</span>
            <span class="font-semibold text-white">${opts.areaDetail}</span>
            ${districtsInline}
            ${popHtml}
          </div>
          ${repsHtml}
          ${footer}
          ${federal}
        `);
      }

      function findByDistricts(districts, areaContext) {
        const reps = districts.flatMap((d) => districtMap[d] || []);
        const ids = reps.map((r) => r.id);
        if (!ids.length) {
          renderAreaCard({
            areaLabel: areaContext.label,
            areaDetail: areaContext.detail,
            districts,
            populationLine: areaContext.populationLine,
            noRepsMessage: `No officials in our seeded roster cover ${districts.join(', ')} yet. Use the search above to find any of the ${Object.keys(districtMap).length} districts in the roster.`,
            footerNote: areaContext.footerNote,
          });
          highlightOfficials([]);
          return;
        }
        renderAreaCard({
          areaLabel: areaContext.label,
          areaDetail: areaContext.detail,
          districts,
          populationLine: areaContext.populationLine,
          reps,
          footerNote: areaContext.footerNote,
        });
        highlightOfficials(ids);
      }

      document.getElementById('zip-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const zip = (document.getElementById('zip-input').value || '').trim();
        if (!/^\d{5}$/.test(zip)) {
          showResult(`<p class="text-wtp-cream/70">Please enter a 5-digit ZIP code.</p>`);
          return;
        }
        // Geocode the ZIP via Nominatim to a lat/lng, then sample a small
        // bbox around it for /people.geo (a ZIP can span district lines).
        showResult(`<p class="text-wtp-cream/70">Looking up ${zip}…</p>`);
        try {
          const geo = await geocodePlace(`${zip}, Pennsylvania, USA`);
          if (!geo) {
            renderAreaCard({
              areaLabel: 'ZIP not found',
              areaDetail: zip,
              footerNote: 'Geocoder could not pinpoint that ZIP. Double-check the digits, or use the address input above.',
            });
            highlightOfficials([]);
            return;
          }
          const reps = geo.bbox
            ? await findRepsAcrossBbox(geo.bbox, geo.lat, geo.lng)
            : await findReps_loose(geo.lat, geo.lng, 1500);
          if (!reps.length) {
            renderAreaCard({
              areaLabel: 'Your ZIP',
              areaDetail: zip,
              noRepsMessage: 'OpenStates returned no PA legislators for this ZIP. Are you sure it is a PA ZIP?',
            });
            highlightOfficials([]);
            return;
          }
          const districts = Array.from(new Set(reps.map((r) => r.district).filter(Boolean))).sort();
          renderAreaCard({
            areaLabel: 'Your ZIP',
            areaDetail: zip,
            districts,
            reps,
            footerNote: reps.length > 2
              ? `ZIP areas can straddle district lines — ${reps.length} legislators serve parts of this ZIP. Type your street address for the exact pair.`
              : 'For your specific street, type your address above.',
          });
          highlightOfficials(reps.map((r) => r.id));
        } catch (err) {
          renderAreaCard({
            areaLabel: 'Lookup failed',
            areaDetail: zip,
            footerNote: 'Could not reach the geocoder. Try the address input. (' + (err && err.message ? err.message : 'unknown') + ')',
          });
        }
      });

      // Lat/lng → OpenStates /people.geo → match to our roster.
      async function findByLatLng(lat, lng, areaContext) {
        if (!openstatesApiKey) {
          renderAreaCard({
            areaLabel: 'Lookup unavailable',
            areaDetail: areaContext.detail,
            footerNote: 'OpenStates API key not configured at build time. Add PUBLIC_OPENSTATES_API_KEY to the build environment.',
          });
          highlightOfficials([]);
          return;
        }
        showResult('<p class="text-wtp-cream/70">Looking up your reps…</p>');
        try {
          const url = `https://v3.openstates.org/people.geo?lat=${lat}&lng=${lng}&apikey=${encodeURIComponent(openstatesApiKey)}`;
          const resp = await fetch(url);
          if (!resp.ok) throw new Error(`OpenStates ${resp.status}`);
          const data = await resp.json();
          const matched = [];
          for (const person of (data.results || [])) {
            const cardMeta = officialsByOcd[person.id];
            if (cardMeta) matched.push(cardMeta);
          }
          if (!matched.length) {
            renderAreaCard({
              areaLabel: areaContext.label,
              areaDetail: areaContext.detail,
              noRepsMessage: 'OpenStates returned reps for this location, but they are not yet in our roster. The roster auto-syncs on the weekly cron.',
              footerNote: areaContext.footerNote,
            });
            highlightOfficials([]);
            return;
          }
          const districts = Array.from(new Set(matched.map((r) => r.district).filter(Boolean)));
          renderAreaCard({
            areaLabel: areaContext.label,
            areaDetail: areaContext.detail,
            districts,
            populationLine: areaContext.populationLine,
            reps: matched,
            footerNote: areaContext.footerNote,
          });
          highlightOfficials(matched.map((r) => r.id));
        } catch (err) {
          renderAreaCard({
            areaLabel: 'Lookup failed',
            areaDetail: areaContext.detail,
            footerNote: 'Could not reach OpenStates. Try the county dropdown or name search instead. (' + (err && err.message ? err.message : 'unknown error') + ')',
          });
          highlightOfficials([]);
        }
      }

      // Browser geolocation → /people.geo
      // Browser-reported coordinates are often imprecise (especially on
      // desktop where positioning is Wi-Fi-based, not GPS). To avoid a
      // boundary-edge case where the imprecise lat/lng falls just over
      // the line into a neighboring district, we sample a small radius
      // around the reported point and present every distinct legislator
      // pair found.
      async function findReps_loose(lat, lng, accuracy) {
        // Convert reported accuracy (meters) into a coordinate radius;
        // clamp to ~500m–2km so even very accurate readings still get
        // a small boundary-tolerance buffer, and very imprecise ones
        // don't sample across an entire county.
        const meters = Math.min(2000, Math.max(500, accuracy || 1500));
        // ~1 degree latitude ≈ 111km
        const radiusDeg = meters / 111000;
        const bbox = {
          south: lat - radiusDeg,
          north: lat + radiusDeg,
          west: lng - radiusDeg / Math.cos(lat * Math.PI / 180),
          east: lng + radiusDeg / Math.cos(lat * Math.PI / 180),
        };
        return findRepsAcrossBbox(bbox, lat, lng);
      }

      document.getElementById('geo-button').addEventListener('click', () => {
        if (!navigator.geolocation) {
          renderAreaCard({
            areaLabel: 'Geolocation not supported',
            areaDetail: 'This browser does not expose location to web pages',
            footerNote: 'Try the address input or county dropdown instead.',
          });
          return;
        }
        if (typeof window !== 'undefined' && !window.isSecureContext) {
          renderAreaCard({
            areaLabel: 'Location blocked on insecure connection',
            areaDetail: 'This page is loading over plain HTTP',
            footerNote: 'Browsers only allow location lookups on HTTPS or localhost. Try the address input or county dropdown instead.',
          });
          return;
        }
        showResult('<p class="text-wtp-cream/70">Asking your browser for location…</p>');
        navigator.geolocation.getCurrentPosition(
          async (pos) => {
            const lat = pos.coords.latitude;
            const lng = pos.coords.longitude;
            const acc = pos.coords.accuracy;
            showResult('<p class="text-wtp-cream/70">Looking up your reps (sampling for accuracy)…</p>');
            try {
              const reps = await findReps_loose(lat, lng, acc);
              if (!reps.length) {
                renderAreaCard({
                  areaLabel: 'Your location',
                  areaDetail: `${lat.toFixed(3)}, ${lng.toFixed(3)}`,
                  noRepsMessage: 'OpenStates returned no PA legislators for nearby points. Are you in PA? Try the address input.',
                });
                highlightOfficials([]);
                return;
              }
              const districts = Array.from(new Set(reps.map((r) => r.district).filter(Boolean))).sort();
              const isApprox = reps.length > 2; // multiple reps = boundary area
              renderAreaCard({
                areaLabel: isApprox ? 'Near your location' : 'Your location',
                areaDetail: `${lat.toFixed(3)}, ${lng.toFixed(3)}${acc ? ` · ±${Math.round(acc)}m` : ''}`,
                districts,
                reps,
                footerNote: isApprox
                  ? `Browser location is approximate so we sampled a small radius — found ${reps.length} legislators across nearby districts. Type your address for the exact pair.`
                  : 'Browser location stays in your browser; only an anonymous lat/lng is sent to OpenStates.',
              });
              highlightOfficials(reps.map((r) => r.id));
            } catch (err) {
              renderAreaCard({
                areaLabel: 'Lookup failed',
                areaDetail: `${lat.toFixed(3)}, ${lng.toFixed(3)}`,
                footerNote: 'Could not reach OpenStates. Try the address input. (' + (err && err.message ? err.message : 'unknown') + ')',
              });
            }
          },
          (err) => {
            // PositionError codes: 1=denied, 2=unavailable, 3=timeout
            const code = err && err.code;
            let label = 'Location not available';
            let detail = (err && err.message) || 'Unknown error';
            let note = 'Try the address input or county dropdown instead.';
            if (code === 1) {
              label = 'Permission denied';
              detail = 'Your browser blocked the location request';
              note = 'Look for a 📍 icon in your address bar (or Site Settings) to allow location for this page, then click "My location" again. Or use the address input above.';
            } else if (code === 2) {
              label = 'Device could not get a location';
              detail = 'No GPS / Wi-Fi positioning signal available';
              note = 'Common on desktop browsers without Wi-Fi positioning. Use the address input above instead — it works the same way.';
            } else if (code === 3) {
              label = 'Location request timed out';
              detail = 'Took longer than 10 seconds';
              note = 'Try again, or use the address input above.';
            }
            renderAreaCard({ areaLabel: label, areaDetail: detail, footerNote: note });
          },
          { timeout: 10000, enableHighAccuracy: false, maximumAge: 60000 },
        );
      });

      // Auto-append ", Pennsylvania" if the user just typed street + town.
      // Saves them from having to know the format.
      function normalizeAddress(input) {
        const s = (input || '').trim();
        if (!s) return s;
        if (/\b(pa|pennsylvania)\b/i.test(s)) return s;
        return `${s}, Pennsylvania`;
      }

      // Address geocoder with two-stage fallback: Census first (most
      // accurate for street addresses), then Nominatim (more forgiving
      // about typos and partial inputs). Both are free and CORS-enabled.
      async function geocodeAddress(address) {
        const normalized = normalizeAddress(address);
        // Stage 1: Census
        try {
          const url = `https://geocoding.geo.census.gov/geocoder/locations/onelineaddress?address=${encodeURIComponent(normalized)}&benchmark=Public_AR_Current&format=json`;
          const resp = await fetch(url);
          if (resp.ok) {
            const data = await resp.json();
            const matches = (data.result && data.result.addressMatches) || [];
            if (matches.length) {
              const c = matches[0].coordinates || {};
              return { lat: c.y, lng: c.x, matched: matches[0].matchedAddress, source: 'Census' };
            }
          }
        } catch (_) { /* fall through to Nominatim */ }
        // Stage 2: Nominatim (forgiving — handles typos, partial inputs)
        const place = await geocodePlace(normalized);
        if (place) return { ...place, source: 'OpenStreetMap' };
        return null;
      }

      // Place-name geocoder for county / city queries (Census's onelineaddress
      // endpoint only accepts street addresses). Nominatim is free and
      // CORS-enabled; usage policy asks for ≤1 req/sec which civic
      // dashboard traffic easily fits inside.
      async function geocodePlace(query) {
        const url = `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(query)}&format=json&limit=1&countrycodes=us&polygon_geojson=0&extratags=0`;
        const resp = await fetch(url, { headers: { 'Accept': 'application/json' } });
        if (!resp.ok) throw new Error(`Nominatim ${resp.status}`);
        const arr = await resp.json();
        if (!Array.isArray(arr) || arr.length === 0) return null;
        const r = arr[0];
        const bbox = Array.isArray(r.boundingbox) && r.boundingbox.length === 4
          ? { south: parseFloat(r.boundingbox[0]), north: parseFloat(r.boundingbox[1]), west: parseFloat(r.boundingbox[2]), east: parseFloat(r.boundingbox[3]) }
          : null;
        return { lat: parseFloat(r.lat), lng: parseFloat(r.lon), matched: r.display_name, bbox };
      }

      // Sample N points across a bounding box and call /people.geo at each.
      // Dedupe results by ocd-person ID so a multi-district county returns
      // every overlapping legislator. Trades 5x API calls for accurate
      // county coverage.
      async function findRepsAcrossBbox(bbox, centerLat, centerLng) {
        const span = 0.85; // pull 5 points slightly inset from edges
        const dy = (bbox.north - bbox.south) * span * 0.5;
        const dx = (bbox.east - bbox.west) * span * 0.5;
        const points = [
          { lat: centerLat, lng: centerLng },
          { lat: centerLat + dy, lng: centerLng + dx },
          { lat: centerLat + dy, lng: centerLng - dx },
          { lat: centerLat - dy, lng: centerLng + dx },
          { lat: centerLat - dy, lng: centerLng - dx },
        ];
        const seen = new Set();
        const out = [];
        const responses = await Promise.all(points.map(async (p) => {
          try {
            const url = `https://v3.openstates.org/people.geo?lat=${p.lat}&lng=${p.lng}&apikey=${encodeURIComponent(openstatesApiKey)}`;
            const r = await fetch(url);
            if (!r.ok) return [];
            const d = await r.json();
            return d.results || [];
          } catch (_) { return []; }
        }));
        for (const arr of responses) {
          for (const person of arr) {
            if (!seen.has(person.id)) {
              seen.add(person.id);
              const cardMeta = officialsByOcd[person.id];
              if (cardMeta) out.push(cardMeta);
            }
          }
        }
        return out;
      }

      document.getElementById('address-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const address = (document.getElementById('address-input').value || '').trim();
        if (!address) return;
        showResult('<p class="text-wtp-cream/70">Geocoding the address…</p>');
        try {
          const geo = await geocodeAddress(address);
          if (!geo) {
            renderAreaCard({
              areaLabel: 'Address not found',
              areaDetail: address,
              footerNote: 'Census geocoder could not resolve this address. Try adding a city or ZIP, or use the county dropdown.',
            });
            highlightOfficials([]);
            return;
          }
          findByLatLng(geo.lat, geo.lng, {
            label: 'Your address',
            detail: geo.matched || address,
            footerNote: 'Geocoded by U.S. Census Bureau (free, no key); reps looked up via OpenStates.',
          });
        } catch (err) {
          renderAreaCard({
            areaLabel: 'Geocoder failed',
            areaDetail: address,
            footerNote: 'Could not reach the Census geocoder. ' + (err && err.message ? err.message : ''),
          });
        }
      });

      document.getElementById('county-select').addEventListener('change', async (e) => {
        const county = e.target.value;
        if (!county) {
          showResult('');
          resultEl.classList.add('hidden');
          highlightOfficials([]);
          return;
        }
        const pop = countyPop[county];
        const popLine = pop
          ? `<strong class="text-white">${fmtNum(pop)}</strong> residents (2020)`
          : '';

        // Path A: counties[] is hand-tagged on at least one official —
        // use the direct mapping. Currently only the 4 seed senators
        // have counties[] populated.
        const taggedReps = countyOfficials[county] || [];
        if (taggedReps.length) {
          const districts = Array.from(new Set(taggedReps.map((r) => r.district).filter(Boolean)));
          renderAreaCard({
            areaLabel: 'Your county',
            areaDetail: `${county} County`,
            districts,
            populationLine: popLine,
            reps: taggedReps,
            footerNote: 'Note: county tagging is hand-curated for the seed senators. Senate districts often span multiple counties — your address may be represented by additional legislators. Try the address input for the most accurate match.',
          });
          highlightOfficials(taggedReps.map((r) => r.id));
          return;
        }

        // Path B: no hand-tagged officials — geocode the county
        // boundary via Nominatim, then sample 5 points across it to
        // catch all overlapping districts (a single centroid only finds
        // one Senator + one Rep, which misleads for multi-district
        // counties like Chester or Allegheny).
        showResult(`<p class="text-wtp-cream/70">Sampling ${county} County's districts…</p>`);
        try {
          const geo = await geocodePlace(`${county} County, Pennsylvania, USA`);
          if (!geo || !geo.bbox) {
            renderAreaCard({
              areaLabel: 'Your county',
              areaDetail: `${county} County`,
              populationLine: popLine,
              noRepsMessage: 'Could not pinpoint this county boundary. Try the address input with a specific street address.',
            });
            highlightOfficials([]);
            return;
          }
          const reps = await findRepsAcrossBbox(geo.bbox, geo.lat, geo.lng);
          if (!reps.length) {
            renderAreaCard({
              areaLabel: 'Your county',
              areaDetail: `${county} County`,
              populationLine: popLine,
              noRepsMessage: 'OpenStates returned no legislators for the points sampled across this county. Try the address input above.',
            });
            highlightOfficials([]);
            return;
          }
          const districts = Array.from(new Set(reps.map((r) => r.district).filter(Boolean))).sort();
          const senateCount = reps.filter((r) => r.chamber === 'Senate').length;
          const houseCount = reps.filter((r) => r.chamber === 'House').length;
          renderAreaCard({
            areaLabel: 'Districts overlapping',
            areaDetail: `${county} County`,
            districts,
            populationLine: popLine,
            reps,
            footerNote: `Sampled across the county boundary; found ${senateCount} Senate district${senateCount === 1 ? '' : 's'} and ${houseCount} House district${houseCount === 1 ? '' : 's'}. For your exact pair, type your street address above.`,
          });
          highlightOfficials(reps.map((r) => r.id));
        } catch (err) {
          renderAreaCard({
            areaLabel: 'Lookup failed',
            areaDetail: `${county} County`,
            populationLine: popLine,
            footerNote: 'Could not reach the geocoder. Try the address input or "Use my location". (' + (err && err.message ? err.message : 'unknown') + ')',
          });
        }
      });
    </script>
  </body>
</html>
