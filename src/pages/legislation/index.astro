---
import '../../styles/global.css';
import { config } from '../../config';
import BillCard from '../../components/legislation/BillCard.astro';
import BrandShortName from '../../components/BrandShortName.astro';
import billsData from '../../../data/legislation/bills.json';
import platform from '../../../data/legislation/platform.json';
import manualReviewDoc from '../../../data/legislation/manual_review.json';

type Alignment = 'aligned' | 'mixed' | 'opposed' | 'topic-only' | 'under-review';
type Source = 'manual' | 'auto' | 'none';
type Stage = 'introduced' | 'committee' | 'on-floor' | 'passed' | 'signed';
type ManualReview = { alignment: 'aligned' | 'mixed' | 'opposed'; note: string; reviewedBy?: string; reviewedAt?: string };

// Confidence threshold above which an auto-alignment is presented as the
// bill's alignment. Below this, the bill renders as "Touches our platform".
const AUTO_ALIGNMENT_THRESHOLD = 0.65;

// Map a status string from OpenStates to a stage in the legislative
// process. PA-specific phrases — extend as new ones show up.
function stageOf(status: string): Stage {
  const s = status.toLowerCase();
  if (s.includes('signed') || s.includes('act of') || s.includes('became law')) return 'signed';
  if (s.includes('passed both') || s.includes('to governor') || s.includes('enacted')) return 'passed';
  if (s.includes('third consideration') || s.includes('passed house') || s.includes('passed senate') || s.includes('on floor') || s.includes('adopted')) return 'on-floor';
  if (s.includes('appropriations')) return 'committee'; // Re-referred to Appropriations = past initial committee
  return 'introduced';
}

const STAGE_LABELS: Record<Stage, string> = {
  introduced: 'Introduced',
  committee: 'In committee',
  'on-floor': 'On floor',
  passed: 'Passed legislature',
  signed: 'Signed into law',
};

const STAGE_ORDER: Record<Stage, number> = {
  signed: 0,
  passed: 1,
  'on-floor': 2,
  committee: 3,
  introduced: 4,
};

// Strip the boilerplate "An Act amending the act of ... known as the X, in Y,
// providing for Z" preamble down to the bill's actual subject. Falls back to
// the raw title if no clean extraction is possible.
function cleanTitle(title: string): string {
  let t = title.trim().replace(/\s+/g, ' ');
  // Try "providing for X" — usually the actual subject of the bill.
  const provMatch = t.match(/(?:further\s+)?providing for (.+?)\.?$/i);
  if (provMatch && provMatch[1].length >= 8) {
    return provMatch[1].trim().replace(/^the\s+/i, '').replace(/^["']|["']$/g, '').replace(/\.$/, '');
  }
  // Try "known as the LAW, in SECTION" — return the law name.
  const knownMatch = t.match(/known as the (.+?)(?:,|\.|$)/i);
  if (knownMatch && knownMatch[1].length >= 8) {
    return knownMatch[1].trim();
  }
  // Strip leading "An Act" and any leading boilerplate.
  t = t.replace(/^an act\s+/i, '');
  // Trim long titles.
  if (t.length > 120) return t.slice(0, 117).trim() + '…';
  return t;
}

const reviews = manualReviewDoc.reviews as Record<string, ManualReview>;

const enriched = billsData.bills
  .filter((bill) => bill.matches.length > 0 || reviews[bill.id])
  .map((bill) => {
    const review = reviews[bill.id];

    let alignment: Alignment;
    let alignmentSource: Source;
    let alignmentConfidence: number | undefined;

    if (review) {
      alignment = review.alignment;
      alignmentSource = 'manual';
    } else if (
      (bill.autoAlignment === 'likely-aligned' || bill.autoAlignment === 'likely-opposed') &&
      bill.autoConfidence >= AUTO_ALIGNMENT_THRESHOLD
    ) {
      alignment = bill.autoAlignment === 'likely-aligned' ? 'aligned' : 'opposed';
      alignmentSource = 'auto';
      alignmentConfidence = bill.autoConfidence;
    } else if (bill.matches.length > 0) {
      alignment = 'topic-only';
      alignmentSource = 'none';
    } else {
      alignment = 'under-review';
      alignmentSource = 'none';
    }

    // Find the primary pillar — the pillar of the strongest match.
    let primaryPillarId = 'unmatched';
    if (bill.matches.length > 0) {
      const top = bill.matches[0];
      for (const pillar of platform.pillars) {
        if (pillar.positions.some((p) => p.id === top.positionId)) {
          primaryPillarId = pillar.id;
          break;
        }
      }
    }

    const stage = stageOf(bill.status);

    return {
      ...bill,
      cleanTitle: cleanTitle(bill.title),
      alignment,
      alignmentSource,
      alignmentConfidence,
      stage,
      primaryPillarId,
      reviewNote: review?.note,
      reviewedBy: review?.reviewedBy,
      reviewedAt: review?.reviewedAt,
    };
  });

const totalFetched = billsData.bills.length;
const filteredOut = totalFetched - enriched.length;

const alignmentOrder: Record<Alignment, number> = {
  aligned: 0, opposed: 1, mixed: 2, 'topic-only': 3, 'under-review': 4,
};

function sortBills<T extends typeof enriched[number]>(bills: T[]): T[] {
  return [...bills].sort((a, b) => {
    const stageDiff = STAGE_ORDER[a.stage] - STAGE_ORDER[b.stage];
    if (stageDiff !== 0) return stageDiff;
    const alignDiff = alignmentOrder[a.alignment] - alignmentOrder[b.alignment];
    if (alignDiff !== 0) return alignDiff;
    return b.lastAction.localeCompare(a.lastAction);
  });
}

const counts = enriched.reduce((acc, b) => {
  acc[b.alignment] = (acc[b.alignment] ?? 0) + 1;
  return acc;
}, {} as Record<Alignment, number>);

// Featured row: bills that have moved beyond initial committee referral. Most
// PA bills die in introduction — a bill on the floor or signed is a much
// bigger deal than one referred yesterday. Cap so the row stays focused.
const featured = sortBills(enriched.filter((b) => b.stage !== 'introduced')).slice(0, 6);
const featuredIds = new Set(featured.map((b) => b.id));

// Group remaining bills by primary pillar for the section view. Bills already
// in the featured row are excluded so they don't appear twice.
const billsByPillar = platform.pillars.map((pillar) => ({
  pillar,
  bills: sortBills(enriched.filter((b) => b.primaryPillarId === pillar.id && !featuredIds.has(b.id))),
}));

// Plain-English pillar tagline override (the `tagline` in platform.json is
// short; here we tell readers what KIND of bills land here).
const PILLAR_BLURBS: Record<string, string> = {
  community: 'Bills about schools, addiction recovery, criminal-justice reform, and elder-care programs.',
  'health-environment': 'Bills about medical freedom, environmental cleanup, food and farming, and access to alternative care.',
  constitutional: 'Bills about civil liberties, judicial reform, transparency, and how the state interacts with foreign governments.',
  'honest-government': 'Bills about elections, redistricting, term limits, and ethics rules for officials.',
  economic: 'Bills about housing, zoning, taxes, and breaking up monopolies.',
};

const lastFetched = new Intl.DateTimeFormat('en-US', {
  dateStyle: 'long', timeStyle: 'short', timeZone: 'America/New_York',
}).format(new Date(billsData.lastFetched));

const pageTitle = `PA Legislation Watch — ${config.party.shortName}`;
const pageDescription = `Tracking Pennsylvania bills against the ${config.party.shortName} platform. ${enriched.length} bills currently monitored.`;
const canonicalUrl = `${config.portfolio.baseUrl}/legislation/`;
const ogImageUrl = `${config.portfolio.baseUrl}/og-legislation.png`;
const projectName = 'PA Legislation Watch';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/wtp-logo.png" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body class="min-h-screen bg-page text-white">
    <header class="border-b border-white/10 px-6 py-4">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 md:grid md:grid-cols-3">
        <a href="/" class="flex min-w-0 items-center gap-3 hover:opacity-80 transition md:justify-self-start">
          <img src={config.brand.logoPath} alt={`${config.party.shortName} logo`} class="h-10 w-auto flex-shrink-0 sm:h-12" />
          <div class="min-w-0 truncate text-base font-semibold sm:text-lg">{projectName}</div>
        </a>
        <a href={config.party.website} class="hidden text-center text-sm text-wtp-cream/70 no-underline hover:text-wtp-sky md:block md:justify-self-center">
          {config.party.name}
        </a>
        <nav class="flex flex-shrink-0 items-center gap-4 text-sm md:justify-self-end">
          <a href="/legislation/about" class="text-wtp-cream/70 no-underline hover:text-wtp-sky">Methodology</a>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-6 py-16 md:py-24">
      <section>
        <p class="text-xs uppercase tracking-[0.2em] text-wtp-sky">Pennsylvania legislation, scored against our platform</p>
        <h1 class="mt-4 text-4xl font-extrabold leading-tight md:text-6xl">PA Legislation Watch</h1>
        <p class="mt-6 max-w-3xl text-base leading-relaxed text-wtp-cream/80 md:text-lg">
          Pennsylvania's General Assembly considers thousands of bills every two years. We pull all of them, screen each one against {config.party.shortName}'s <a href={`${config.party.website}/platform`} class="text-wtp-sky underline">5 platform pillars</a>, and surface only the bills that actually touch what we stand for. Click any bill to see why we flagged it.
        </p>

        <div class="mt-10 grid grid-cols-2 gap-3 text-sm md:grid-cols-4">
          <div class="rounded-lg border border-wtp-sky/30 bg-wtp-sky/5 px-4 py-3">
            <div class="text-2xl font-bold text-wtp-sky">{counts.aligned ?? 0}</div>
            <div class="mt-1 text-xs uppercase tracking-wider text-wtp-cream/60">Aligned</div>
          </div>
          <div class="rounded-lg border border-wtp-gold/30 bg-wtp-gold/5 px-4 py-3">
            <div class="text-2xl font-bold text-wtp-gold">{counts.mixed ?? 0}</div>
            <div class="mt-1 text-xs uppercase tracking-wider text-wtp-cream/60">Mixed</div>
          </div>
          <div class="rounded-lg border border-wtp-red/30 bg-wtp-red/5 px-4 py-3">
            <div class="text-2xl font-bold text-wtp-red">{counts.opposed ?? 0}</div>
            <div class="mt-1 text-xs uppercase tracking-wider text-wtp-cream/60">Opposed</div>
          </div>
          <div class="rounded-lg border border-white/10 bg-white/5 px-4 py-3">
            <div class="text-2xl font-bold text-wtp-cream/70">{(counts['topic-only'] ?? 0) + (counts['under-review'] ?? 0)}</div>
            <div class="mt-1 text-xs uppercase tracking-wider text-wtp-cream/60">Touches platform</div>
          </div>
        </div>
        <p class="mt-3 text-xs text-wtp-cream/50">
          "Aligned" and "Opposed" combine editor reviews with auto-detected calls (≥{Math.round(AUTO_ALIGNMENT_THRESHOLD * 100)}% confidence). "Touches platform" means the topic matched but the bill's direction needs a human read.
        </p>
      </section>

      <details id="how-bill-becomes-law" open class="group mt-12 rounded-lg border border-white/10 bg-surface/40 transition hover:border-white/20">
        <summary class="flex cursor-pointer list-none items-baseline justify-between gap-3 p-6 md:p-8">
          <div class="min-w-0">
            <h2 class="text-base font-semibold text-white">How a bill becomes a law in Pennsylvania</h2>
            <p class="mt-1 text-xs text-wtp-cream/60">
              5 steps from introduction to law. Of the 4,000+ bills filed each session, only a few hundred make it past committee.
            </p>
          </div>
          <span class="flex-shrink-0 text-xs text-wtp-cream/40 transition group-open:rotate-90 inline-block w-3" aria-hidden="true">▸</span>
        </summary>
        <div class="px-6 pb-6 md:px-8 md:pb-8">
          <ol class="grid grid-cols-1 gap-3 text-xs text-wtp-cream/70 md:grid-cols-5 md:gap-2">
            <li class="rounded-md border border-white/10 bg-white/5 p-3">
              <div class="font-semibold text-wtp-cream/90">1. Introduced</div>
              <div class="mt-1">A legislator files the bill. Most stop here.</div>
            </li>
            <li class="rounded-md border border-white/10 bg-white/5 p-3">
              <div class="font-semibold text-wtp-cream/90">2. In committee</div>
              <div class="mt-1">A subject-matter committee reviews it. It can be amended, voted out, or shelved.</div>
            </li>
            <li class="rounded-md border border-white/10 bg-white/5 p-3">
              <div class="font-semibold text-wtp-cream/90">3. On floor</div>
              <div class="mt-1">The full chamber debates and votes (House and Senate each do this).</div>
            </li>
            <li class="rounded-md border border-white/10 bg-white/5 p-3">
              <div class="font-semibold text-wtp-cream/90">4. Passed legislature</div>
              <div class="mt-1">Both chambers agreed on the same text. Goes to the Governor.</div>
            </li>
            <li class="rounded-md border border-white/10 bg-white/5 p-3">
              <div class="font-semibold text-wtp-cream/90">5. Signed into law</div>
              <div class="mt-1">The Governor signs it (or it becomes law without signature after 10 days).</div>
            </li>
          </ol>
          <p class="mt-4 text-xs text-wtp-cream/50">
            We sort each pillar's list with the most-advanced bills first.
          </p>
        </div>
      </details>
      <script is:inline>
        // Default the "How a bill becomes a law" section to collapsed on
        // mobile so the steps grid doesn't push the bill list far below the
        // fold. Desktop keeps it open since it fits horizontally as 5 cards.
        (() => {
          const el = document.getElementById('how-bill-becomes-law');
          if (el && window.matchMedia('(max-width: 767px)').matches) {
            el.removeAttribute('open');
          }
        })();
      </script>

      {featured.length > 0 && (
        <section class="mt-16 bill-section" data-section-name="featured">
          <div class="flex items-baseline gap-3">
            <h2 class="text-2xl font-bold md:text-3xl">⭐ Bills that have moved</h2>
            <div class="text-xs text-wtp-cream/50">past introduction</div>
          </div>
          <p class="mt-2 max-w-3xl text-sm text-wtp-cream/70">
            These are the bills worth paying attention to right now — they've made it past initial committee referral and are actually on track to be voted on.
          </p>
          <div class="mt-6 space-y-3">
            {featured.map((bill) => (
              <div class="bill-row" data-alignment={bill.alignment}>
                <BillCard
                  id={bill.id}
                  chamber={bill.chamber}
                  title={bill.cleanTitle}
                  sponsor={bill.sponsor}
                  status={`${STAGE_LABELS[bill.stage]} · ${bill.status}`}
                  lastAction={bill.lastAction}
                  url={bill.url}
                  summary={bill.summary}
                  matches={bill.matches}
                  alignment={bill.alignment}
                  alignmentSource={bill.alignmentSource}
                  alignmentConfidence={bill.alignmentConfidence}
                  reviewNote={bill.reviewNote}
                  reviewedBy={bill.reviewedBy}
                  reviewedAt={bill.reviewedAt}
                />
              </div>
            ))}
          </div>
          <p class="mt-4 hidden text-sm italic text-wtp-cream/50 empty-msg">
            None of the featured bills match this filter.
          </p>
        </section>
      )}

      <section class="mt-16">
        <div class="flex flex-wrap items-baseline justify-between gap-3">
          <h2 class="text-2xl font-bold md:text-3xl">Bills by platform pillar · {billsData.session}</h2>
          <div class="text-xs text-wtp-cream/50">Updated {lastFetched}</div>
        </div>
        <p class="mt-2 text-xs text-wtp-cream/50">
          {totalFetched.toLocaleString()} bills fetched from <a href="https://openstates.org/pa/" class="text-wtp-cream/70 underline hover:text-wtp-sky" target="_blank" rel="noopener">OpenStates</a>; {filteredOut.toLocaleString()} hidden because they don't touch any of our planks.
        </p>

        <div class="mt-8 space-y-4">
          {billsByPillar.map(({ pillar, bills }, idx) => (
            bills.length === 0 ? null : (
              <details class="bill-section group rounded-lg border border-white/10 bg-surface/30 transition hover:border-white/20" data-section-name={pillar.id}>
                <summary class="flex cursor-pointer list-none items-baseline justify-between gap-3 px-5 py-4">
                  <div class="flex items-baseline gap-3">
                    <span class="text-xs text-wtp-cream/40 transition group-open:rotate-90 inline-block w-3" aria-hidden="true">▸</span>
                    <h3 class="text-xl font-bold text-white">{pillar.name}</h3>
                  </div>
                  <div class="text-xs text-wtp-cream/50">{bills.length} {bills.length === 1 ? 'bill' : 'bills'}</div>
                </summary>
                <div class="border-t border-white/5 px-5 pb-5 pt-4">
                  <p class="mb-5 text-sm text-wtp-cream/70">{PILLAR_BLURBS[pillar.id] ?? pillar.tagline}</p>
                  <div class="space-y-3">
                    {bills.map((bill) => (
                      <div class="bill-row" data-alignment={bill.alignment}>
                        <BillCard
                          id={bill.id}
                          chamber={bill.chamber}
                          title={bill.cleanTitle}
                          sponsor={bill.sponsor}
                          status={`${STAGE_LABELS[bill.stage]} · ${bill.status}`}
                          lastAction={bill.lastAction}
                          url={bill.url}
                          summary={bill.summary}
                          matches={bill.matches}
                          alignment={bill.alignment}
                          alignmentSource={bill.alignmentSource}
                          alignmentConfidence={bill.alignmentConfidence}
                          reviewNote={bill.reviewNote}
                          reviewedBy={bill.reviewedBy}
                          reviewedAt={bill.reviewedAt}
                        />
                      </div>
                    ))}
                  </div>
                  <p class="mt-4 hidden text-sm italic text-wtp-cream/50 empty-msg">
                    No bills in this pillar match the current filter.
                  </p>
                </div>
              </details>
            )
          ))}
        </div>
      </section>

      <section class="mt-20 rounded-lg border border-wtp-sky/20 bg-gradient-to-br from-wtp-navy/60 to-wtp-indigo/40 p-8 md:p-12">
        <p class="text-xs uppercase tracking-[0.25em] text-wtp-sky">{config.party.tagline}</p>
        <h2 class="mt-4 text-3xl font-extrabold leading-tight md:text-4xl">Want a state party that reads the bills?</h2>
        <p class="mt-5 max-w-2xl text-base leading-relaxed text-wtp-cream/90 md:text-lg">
          Most Pennsylvania bills never make it past committee — but the ones that do shape your daily life. We screen each one against {config.party.shortName}'s platform so you don't have to. Become a member to help us keep watch.
        </p>
        <div class="mt-6">
          <a href={config.party.website} class="inline-flex items-center gap-2 rounded-md bg-wtp-sky px-6 py-3 text-sm font-semibold text-wtp-navy no-underline transition hover:bg-wtp-sky/90">
            <span>Join</span>
            <BrandShortName primaryClass="text-wtp-navy" accentClass="text-wtp-red" />
            <span>→</span>
          </a>
        </div>
      </section>
    </main>

    <footer class="border-t border-white/10 px-6 py-8 text-xs text-wtp-cream/50">
      <div class="mx-auto flex max-w-6xl flex-col gap-3 md:flex-row md:justify-between">
        <div>Built by {config.party.name}</div>
        <div class="flex gap-4">
          <a href={config.party.website} class="hover:text-white">wtpppa.org</a>
          <a href={config.party.socials.twitter} class="hover:text-white">X</a>
          <a href={config.party.socials.facebook} class="hover:text-white">Facebook</a>
          <a href="/legislation/about" class="hover:text-white">Methodology</a>
        </div>
      </div>
    </footer>
  </body>
</html>
